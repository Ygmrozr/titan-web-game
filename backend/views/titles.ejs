<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Titles</title>

  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">


  <%- include("partials/music") %>
  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      min-height:100vh;
      overflow:hidden;
      font-family:"Inter", sans-serif;
      background:#111;
      color:#f5f0e6;
    }

    .page{
      position:relative;
      width:100%;
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:20px;
      background:url("/images/image2.jpg") center/cover no-repeat;
      isolation:isolate;
    }

    .page::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at center,
          rgba(0,0,0,0.02) 25%,
          rgba(0,0,0,0.22) 72%,
          rgba(0,0,0,0.42) 100%);
      z-index:1;
      pointer-events:none;
    }

    .page::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(rgba(18,14,10,0.12), rgba(18,14,10,0.12));
      z-index:1;
      pointer-events:none;
    }

    .panel{
      position:relative;
      z-index:5;
      width:min(980px, 96vw);
      max-height:92vh;
      overflow:hidden;
      border-radius:24px;
      background:rgba(32, 24, 16, 0.54);
      backdrop-filter:blur(10px);
      -webkit-backdrop-filter:blur(10px);
      border:1px solid rgba(255,255,255,0.10);
      box-shadow:
        0 20px 50px rgba(0,0,0,0.30),
        inset 0 1px 0 rgba(255,255,255,0.08);
    }

    .panel::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.05), transparent 18%, transparent 82%, rgba(0,0,0,0.06));
      pointer-events:none;
    }

    .content{
      position:relative;
      z-index:2;
      padding:26px 26px 20px;
      display:flex;
      flex-direction:column;
      gap:18px;
    }

    .topbar{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
    }

    .heading h1{
      font-family:"Cinzel", serif;
      font-size:34px;
      line-height:1.1;
      letter-spacing:0.5px;
      color:#f4e7c8;
      text-shadow:0 2px 8px rgba(0,0,0,0.25);
      margin-bottom:6px;
    }

    .heading p{
      font-size:13px;
      color:rgba(255,245,225,0.78);
    }

    .back-btn{
      text-decoration:none;
      border:none;
      cursor:pointer;
      font-family:"Cinzel", serif;
      font-size:14px;
      font-weight:700;
      color:#4f3920;
      padding:12px 18px;
      border-radius:12px;
      background:linear-gradient(180deg, #f2dfb5, #d8b87a);
      box-shadow:
        0 8px 18px rgba(0,0,0,0.18),
        inset 0 1px 0 rgba(255,255,255,0.35);
      transition:all 0.18s ease;
      flex-shrink:0;
    }

    .back-btn:hover{
      transform:translateY(-2px);
      box-shadow:
        0 10px 22px rgba(0,0,0,0.22),
        inset 0 1px 0 rgba(255,255,255,0.35);
    }

    .back-btn:active{
      transform:scale(0.97);
    }

    .hero{
      display:grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap:16px;
    }

    .hero-card,
    .stats-card{
      border-radius:18px;
      padding:18px 18px 16px;
      background:rgba(255,255,255,0.07);
      border:1px solid rgba(255,255,255,0.08);
      box-shadow:inset 0 1px 0 rgba(255,255,255,0.06);
    }

    .hero-label,
    .stats-label{
      font-family:"Cinzel", serif;
      font-size:13px;
      letter-spacing:1px;
      text-transform:uppercase;
      color:#d9bd87;
      margin-bottom:8px;
    }

    .current-title{
      font-family:"Cinzel", serif;
      font-size:28px;
      color:#7ed8ff;
      line-height:1.2;
      text-shadow:0 2px 10px rgba(0,0,0,0.18);
      margin-bottom:8px;
    }

    .hero-text{
      font-size:13px;
      line-height:1.7;
      color:rgba(255,245,225,0.82);
    }

    .stats-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
      margin-top:8px;
    }

    .stat-box{
      border-radius:14px;
      padding:14px 14px 12px;
      background:rgba(0,0,0,0.16);
      border:1px solid rgba(255,255,255,0.06);
    }

    .stat-name{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:0.8px;
      color:rgba(255,235,205,0.65);
      margin-bottom:6px;
    }

    .stat-value{
      font-family:"Cinzel", serif;
      font-size:24px;
      color:#f5e7c8;
    }

    .titles-wrap{
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
      gap:12px;
    }

    .title-card{
      position:relative;
      border-radius:16px;
      padding:14px 14px 12px;
      background:rgba(255,255,255,0.08);
      border:1px solid rgba(255,255,255,0.08);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.06),
        0 4px 12px rgba(0,0,0,0.06);
      transition:all 0.18s ease;
      min-height:102px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
    }

    .title-card:hover{
      transform:translateY(-2px);
      box-shadow:
        0 10px 20px rgba(0,0,0,0.14),
        inset 0 1px 0 rgba(255,255,255,0.08);
    }

    .title-card.unlocked{
      background:
        linear-gradient(180deg, rgba(255,243,217,0.16), rgba(255,220,150,0.08));
      border-color:rgba(220,185,110,0.28);
    }

    .title-card.locked{
      background:
        linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.04));
    }

    .title-head{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:10px;
      margin-bottom:8px;
    }

    .title-name{
      font-family:"Cinzel", serif;
      font-size:17px;
      line-height:1.3;
      color:#f4e7c8;
    }

    .title-icon{
      font-size:18px;
      flex-shrink:0;
    }

    .title-desc{
      font-size:12px;
      line-height:1.6;
      color:rgba(255,245,225,0.75);
      margin-bottom:8px;
    }

    .title-requirement{
      font-size:12px;
      color:#d8bd8b;
      line-height:1.5;
    }

    .title-requirement strong{
      color:#fff0d0;
    }

    .footer-note{
      text-align:center;
      font-size:12px;
      color:rgba(255,245,225,0.66);
      padding-top:2px;
    }

    @media (max-width: 860px){
      .hero{
        grid-template-columns:1fr;
      }

      .titles-wrap{
        grid-template-columns:1fr;
      }

      .panel{
        max-height:94vh;
      }

      .content{
        overflow:auto;
      }
    }

    @media (max-width: 560px){
      .content{
        padding:18px 16px 16px;
      }

      .heading h1{
        font-size:28px;
      }

      .current-title{
        font-size:23px;
      }

      .title-name{
        font-size:15px;
      }

      .back-btn{
        width:100%;
        text-align:center;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="panel">
      <div class="content">

        <div class="topbar">
          <div class="heading">
            <h1>Titles</h1>
            <p>Earn prestige titles as your legend grows.</p>
          </div>

          <a class="back-btn" href="/menu">Back to Menu</a>
        </div>

        <div class="hero">
          <div class="hero-card">
            <div class="hero-label">Current Title</div>
            <div class="current-title"><%= user.title %></div>
            <div class="hero-text">
              Your title reflects your progress and reputation on the battlefield.
              Defeat more titans to unlock greater honors.
            </div>
          </div>

          <div class="stats-card">
            <div class="stats-label">Progress</div>
            <div class="stats-grid">
              <div class="stat-box">
                <div class="stat-name">Titan Kills</div>
                <div class="stat-value"><%= user.titanKills %></div>
              </div>
              <div class="stat-box">
                <div class="stat-name">Unlocked</div>
                <div class="stat-value">
                  <%= titleList.filter(title => user.titanKills >= title.minKills).length %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="titles-wrap">
          <% titleList.forEach(title => { 
               const unlocked = user.titanKills >= title.minKills;
          %>
            <div class="title-card <%= unlocked ? 'unlocked' : 'locked' %>">
              <div>
                <div class="title-head">
                  <div class="title-name"><%= title.name %></div>
                  <div class="title-icon"><%= unlocked ? '✅' : '🔒' %></div>
                </div>

                <div class="title-desc">
                  <%= unlocked 
                    ? 'Unlocked and available as part of your identity.' 
                    : 'Still locked. Keep fighting to earn this title.' %>
                </div>
              </div>

              <div class="title-requirement">
                Unlocks at <strong><%= title.minKills %></strong> titan kills
              </div>
            </div>
          <% }) %>
        </div>

        <div class="footer-note">
          Titles are unlocked permanently once their requirements are met.
        </div>

      </div>
    </div>
  </div>
</body>
</html>