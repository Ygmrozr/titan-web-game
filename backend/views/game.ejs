<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <title>Giants Game</title>
  <style>
    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      background:#0b0b0b;
      color:white;
      display:flex;
      justify-content:center;
      align-items:center;
      min-height:100vh;
      flex-direction:column;
      gap:12px;
      overflow:hidden;
    }

    .topbar{
      width:1000px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      font-size:18px;
      font-weight:bold;
    }

    .help{
      width:1200px;
      font-size:14px;
      opacity:.95;
      line-height:1.5;
    }
    .menu-bar{
  width:900px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  color:white;
  margin-bottom:10px;
}

.menu-links a{
  color:white;
  text-decoration:none;
  margin-left:16px;
  font-weight:bold;
}

.menu-links a:hover{
  text-decoration:underline;
}

    canvas{
      background:linear-gradient(to top, #1a1a1a 0%, #101820 55%, #0a1018 100%);
      border:2px solid #d8d8d8;
      display:block;
      cursor:crosshair;
      box-shadow:0 0 30px rgba(255,255,255,.08);
    }
    
  </style>
</head>
<body>
  <div 
  id="gameMeta"
  data-objective-type="<%= sectorData.objectiveType %>"
  data-target-kill-count="<%= sectorData.enemyCount || 0 %>"
  data-target-item-count="<%= sectorData.itemTarget || 0 %>"
  data-spawn-enemy-count="<%= sectorData.objectiveType === 'kill' && Number(sector) !== 10 ? (sectorData.enemyCount || 0) + 3 : (sectorData.enemyCount || 0) %>"
  data-spawn-gas-count="<%= sectorData.objectiveType === 'collect' ? (sectorData.itemTarget || 0) + 2 : 2 %>"
  data-level="<%= level %>"
  data-sector="<%= sector %>"
></div>

  <div class="objective-hud">
  <div>Level <%= level %> - Sector <%= sector %></div>
  <div><%= sectorData.objectiveText %></div>

  <div id="objectiveProgress">
  <% if (sectorData.objectiveType === "reach") { %>
    NOT REACHED
  <% } else { %>
    0 / <%= sectorData.itemTarget || sectorData.enemyCount %>
  <% } %>
</div>

</div>


  <% if (devMode) { %>
<div style="position:fixed; bottom:20px; left:20px; background:black; color:white; padding:10px;">
  DEV MODE<br>
  <a href="/game/1/1?dev=1">1-1</a>
  <a href="/game/1/2?dev=1">1-2</a>
  <a href="/game/1/3?dev=1">1-3</a>
  <a href="/game/1/4?dev=1">1-4</a>
  <a href="/game/1/5?dev=1">1-5</a>
  <a href="/game/1/6?dev=1">1-6</a>
  <a href="/game/1/7?dev=1">1-7</a>
  <a href="/game/1/8?dev=1">1-8</a>
  <a href="/game/1/9?dev=1">1-9</a>
  <a href="/game/1/10?dev=1">1-10</a>
  <a href=>------</a>
  <a href="/game/2/1?dev=1">2-1</a>
  <a href="/game/3/1?dev=1">3-1</a>
  <a href="/game/4/1?dev=1">4-1</a>
  <a href="/game/5/1?dev=1">5-1</a>
</div>
<% } %>
  <div class="menu-bar">
  <div>Player: <%= user.username %></div>
  <div class="menu-links">
    <a href="/profile">Profile</a>
    <a href="/menu">Main Menu</a>
    <a href="/map">Map</a>
    <a href="/logout">Logout</a>
  </div>
</div>

  <div class="topbar">
    <div>Oyuncu: <%= user.username || "Player" %></div>
    <div id="scoreText">Score: 0</div>
  </div>

  <div class="help">
    Hareket: A / D veya ← / → | Zıplama: W / ↑ | Saldırı: Space | Halat: Mouse | Restart: R
  </div>

  <canvas id="gameCanvas" width="1200" height="650"></canvas>
  

  <button id="completeSectorBtn" style="
  display:none;
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 9999;
  padding: 12px 16px;
  background: #1f8bff;
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
">
  Complete Sector
</button>



  <script>

    const canvas = document.getElementById("gameCanvas");
    const ctx = canvas.getContext("2d");
    const scoreText = document.getElementById("scoreText");

    const levelBackground = new Image();
levelBackground.src = "/images/levels/trost.png";

    const WORLD = {
      width: 3900,
      height: 560
    };

    const camera = { x: 0 };

    const game = {
      state: "playing",
      message: "",
      maxProgressX: 80,
      invincibleTimer: 0
    };

    const ground = {
  x: 0,
  y: 600,
  width: WORLD.width,
  height: 35
};

    const player = {
      x: 80,
      y: ground.y - 46,
      width: 28,
      height: 46,
      vx: 0,
      vy: 0,

      speed: 3.0,
      maxRunSpeed: 4.4,
      gravity: 0.58,
      jumpPower: -5.8,

      onGround: false,
      facing: 1,

      grappling: false,
      grappleTarget: null,
      grapplePull: 0.82,
      airFriction: 0.992,
      groundFriction: 0.78,
      maxGrappleDistance: 430,

      boostMode: false,
      boostTimer: 0,

      maxHealth: 100,
      health: 100,

      maxGas: 100,
      gas: 100,

      attackTimer: 0,
      attackCooldown: 0,
      hitFlashTimer: 0
    };

    const keys = {};

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function randInt(min, max) {
      return Math.floor(rand(min, max + 1));
    }

    function rectsCollide(a, b) {
      return (
        a.x < b.x + b.width &&
        a.x + a.width > b.x &&
        a.y < b.y + b.height &&
        a.y + a.height > b.y
      );
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function dist(ax, ay, bx, by) {
      const dx = bx - ax;
      const dy = by - ay;
      return Math.sqrt(dx * dx + dy * dy);
    }

    function getPlayerRect() {
      return {
        x: player.x,
        y: player.y,
        width: player.width,
        height: player.height
      };
    }

    function createTitan(x, minX, maxX, dir = 1) {
      const height = randInt(82, 130);
      const width = Math.floor(height * 0.42);
      const hp = Math.max(2, Math.floor(height / 34));

      return {
        x,
        y: ground.y - height,
        width,
        height,
        alive: true,
        dir,
        faceDir: dir,
        minX,
        maxX,
        moveSpeed: rand(0.55, 1.0),
        maxHealth: hp,
        health: hp,
        hitCooldown: 0,
        attackCooldown: 0,
        stunTimer: 0,
        attackFlashTimer: 0,
        damage: randInt(10, 18),
        bloodTimer: 0
      };
    }

    const titanSpawnSlots = [
      620, 950, 1280, 1600, 1930,
      2240, 2550, 2860, 3180, 3480
    ];

    const itemSlots = [
      { x: 250, y: 344 },
      { x: 610, y: 264 },
      { x: 1035, y: 234 },
      { x: 1515, y: 254 },
      { x: 2030, y: 214 },
      { x: 2310, y: 274 },
      { x: 2570, y: 229 },
      { x: 3125, y: 244 },
      { x: 3375, y: 294 },
      { x: 3575, y: 249 }
    ];

    function createBossTitan() {
      const boss = createTitan(3450, 3300, 3650, -1);

      boss.height = 170;
      boss.width = 75;
      boss.y = ground.y - boss.height;
      boss.maxHealth = 12 + currentBattle * 3;
      boss.health = boss.maxHealth;
      boss.damage = 25 + currentBattle * 3;
      boss.moveSpeed = 0.7 + currentBattle * 0.08;
      boss.isBoss = true;

      return boss;
    }

    function spawnTitansBySector() {
      titans.length = 0;

      if (currentSectorNumber === 10) {
        titans.push(createBossTitan());
        return;
      }

      for (let i = 0; i < spawnEnemyCount; i++) {
        const x = titanSpawnSlots[i] || 650 + i * 290;
        const minX = Math.max(500, x - 90);
        const maxX = Math.min(WORLD.width - 120, x + 120);
        const dir = i % 2 === 0 ? 1 : -1;

        const titan = createTitan(x, minX, maxX, dir);

        if (currentBattle === 2) {
          titan.moveSpeed *= 1.15;
        }

        if (currentBattle === 3) {
          titan.maxHealth += 3;
          titan.health = titan.maxHealth;
          titan.damage += 5;
          titan.moveSpeed *= 1.05;
        }

        if (currentBattle >= 4) {
          titan.maxHealth += 1;
          titan.health = titan.maxHealth;
          titan.damage += 3;
        }

        if (currentBattle === 5) {
          titan.maxHealth += 2;
          titan.health = titan.maxHealth;
          titan.damage += 4;
          titan.moveSpeed *= 1.08;
        }

        titans.push(titan);
      }
    }

    function createItem(kind, slotIndex) {
      const slot = itemSlots[slotIndex % itemSlots.length];

      const base = {
        x: slot.x,
        y: slot.y,
        width: 18,
        height: 18,
        collected: false,
        kind
      };

      if (kind === "gas") {
        return { ...base, score: 20, gas: 40 };
      }

      if (kind === "medkit") {
        return { ...base, score: 25, heal: 35 };
      }

      if (kind === "boost") {
        return { ...base, score: 180 };
      }

      return { ...base, score: 50 };
    }

    function spawnItemsBySector() {
      items.length = 0;

      let slotIndex = 0;
      const gasCount = objectiveType === "collect" ? spawnGasCount : 2;

      for (let i = 0; i < gasCount; i++) {
        items.push(createItem("gas", slotIndex++));
      }

      items.push(createItem("medkit", slotIndex++));
      items.push(createItem("boost", slotIndex++));

      if (objectiveType !== "collect") {
        items.push(createItem("score", slotIndex++));
        items.push(createItem("score", slotIndex++));
      }
    }

    function setupSectorContent() {
      spawnTitansBySector();
      spawnItemsBySector();
    }


    const titans = [];

    const items = [];

    const finish = {
      x: 3820,
      y: 330,
      width: 60,
      height: 160
    };

    let killScore = 0;
    let itemScore = 0;
    const bloodEffects = [];
    let titanKillCount = 0;
    let itemCollectedCount = 0;
    let collectedSupplyCount = 0;
    let scoreSaved = false;
    let lastUnlockedTitle = null;

    function spawnBlood(x, y, count = 10) {
      for (let i = 0; i < count; i++) {
        bloodEffects.push({
          x,
          y,
          vx: rand(-2.8, 2.8),
          vy: rand(-3.2, -0.6),
          life: randInt(18, 32),
          size: rand(2, 5)
        });
      }
    }

    function updateBloodEffects() {
      for (let i = bloodEffects.length - 1; i >= 0; i--) {
        const p = bloodEffects[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.18;
        p.life--;
        if (p.life <= 0) bloodEffects.splice(i, 1);
      }
    }

    function getDistanceScore() {
      return Math.max(0, Math.floor((game.maxProgressX - 80) / 16));
    }

    function getTotalScore() {
      return getDistanceScore() + killScore + itemScore;
    }

    async function setWin(message) {
  if (game.state !== "playing") return;

  const result = await saveScoreToDatabase();

  game.state = "win";
  game.message = message;
  player.vx = 0;
  player.vy = 0;
  player.grappling = false;
  player.grappleTarget = null;

  if(result && result.unlockedTitle){
    game.message += " | New Title: " + result.unlockedTitle;
  }
}

async function setLose(message) {
  if (game.state !== "playing") return;

  const result = await saveScoreToDatabase();

  game.state = "lose";
  game.message = message;
  player.vx = 0;
  player.vy = 0;
  player.grappling = false;
  player.grappleTarget = null;

  if(result && result.unlockedTitle){
    game.message += " | New Title: " + result.unlockedTitle;
  }
}

    function resetGame() {
      scoreSaved = false;
      player.x = 80;
      player.y = ground.y - player.height;
      player.vx = 0;
      player.vy = 0;
      player.onGround = true;
      player.facing = 1;
      player.grappling = false;
      player.grappleTarget = null;
      player.boostMode = false;
      player.boostTimer = 0;
      player.health = player.maxHealth;
      player.gas = player.maxGas;
      player.attackTimer = 0;
      player.attackCooldown = 0;
      player.hitFlashTimer = 0;

      camera.x = 0;
      killScore = 0;
      itemScore = 0;
      titanKillCount = 0;
      itemCollectedCount = 0;
      collectedSupplyCount = 0;
      game.maxProgressX = 80;
      game.state = "playing";
      game.message = "";
      game.invincibleTimer = 0;

      bloodEffects.length = 0;

      setupSectorContent();

      document.getElementById("completeSectorBtn").style.display = "none";
    }


    function startGrapple(target) {
      if (player.gas <= 0) return;

      const gasCost = 10;
      if (player.gas < gasCost) return;

      player.gas -= gasCost;

      const px = player.x + player.width / 2;
      const py = player.y + player.height / 2;

      player.grappling = true;
      player.grappleTarget = { x: target.x, y: target.y };

      const dx = target.x - px;
      const dy = target.y - py;
      const len = Math.max(1, Math.sqrt(dx * dx + dy * dy));

      player.vx += (dx / len) * 3.4;
      player.vy += (dy / len) * 3.4;
      player.onGround = false;
    }

    function getSlashHitbox() {
      const width = 52;
      const height = 28;
      const x = player.facing === 1 ? player.x + player.width - 4 : player.x - width + 4;
      const y = player.y + 8;
      return { x, y, width, height };
    }

    function attackTitanIfPossible(titan) {
      if (!titan.alive || titan.hitCooldown > 0 || player.attackTimer <= 0) return false;

      const slash = getSlashHitbox();

      const nape = {
        x: titan.x + titan.width * 0.08,
        y: titan.y + titan.height * 0.10,
        width: titan.width * 0.84,
        height: titan.height * 0.34
      };

      const playerCenterX = player.x + player.width / 2;
      const playerCenterY = player.y + player.height / 2;
      const titanCenterX = titan.x + titan.width / 2;
      const titanCenterY = titan.y + titan.height / 2;

      const behindTitan =
        (titan.faceDir === 1 && playerCenterX < titanCenterX + titan.width * 0.38) ||
        (titan.faceDir === -1 && playerCenterX > titanCenterX - titan.width * 0.38);

      const highEnough = playerCenterY < titanCenterY + titan.height * 0.18;
      const closeEnough = dist(playerCenterX, playerCenterY, titanCenterX, titanCenterY) < 135;

      if (rectsCollide(slash, nape) && behindTitan && highEnough && closeEnough) {
        let damage = 1;
        if (player.boostMode) {
          damage = 2;
        } else if (Math.abs(player.vx) > 4.8 || Math.abs(player.vy) > 5.2) {
          damage = 2;
        }

        titan.health -= damage;
        titan.hitCooldown = 16;
        titan.bloodTimer = 14;
        titan.stunTimer = 28;

        const bloodX = titan.x + titan.width / 2;
        const bloodY = titan.y + titan.height * 0.22;
        spawnBlood(bloodX, bloodY, player.boostMode ? 18 : 12);

        // vurduğu tarafta kalsın
        if (playerCenterX < titanCenterX) {
          player.x = Math.min(player.x, titan.x - player.width - 2);
        } else {
          player.x = Math.max(player.x, titan.x + titan.width + 2);
        }

        player.vx *= 0.35;
        player.vy = Math.min(player.vy, -2.8);

        if (titan.health <= 0) {
          titan.alive = false;
          killScore += titan.maxHealth * 140;
          spawnBlood(bloodX, bloodY, 22);
          titanKillCount++;
          updateObjectiveProgress();
        }

        return true;
      }

      return false;
    }

    function damagePlayer(amount, titanX) {
      if (game.invincibleTimer > 0 || game.state !== "playing") return;

      player.health -= amount;
      game.invincibleTimer = 65;
      player.hitFlashTimer = 18;

      const knockDir = (player.x + player.width / 2) < titanX ? -1 : 1;
      player.vx = 5.0 * knockDir;
      player.vy = -6.0;
      player.grappling = false;
      player.grappleTarget = null;

      spawnBlood(player.x + player.width / 2, player.y + player.height / 2, 8);

      if (player.health <= 0) {
        player.health = 0;
        setLose("Canın bitti!");
      }
    }

    function titanCanAttackPlayer(titan) {
      const playerCenterX = player.x + player.width / 2;
      const playerCenterY = player.y + player.height / 2;
      const titanCenterX = titan.x + titan.width / 2;
      const titanFrontReach = titan.width * 0.72;
      const titanTop = titan.y + 10;
      const titanBottom = titan.y + titan.height - 10;

      const inVerticalRange =
        playerCenterY > titanTop &&
        playerCenterY < titanBottom;

      const inFront =
        (titan.faceDir === 1 &&
          playerCenterX >= titanCenterX + 2 &&
          playerCenterX <= titanCenterX + titanFrontReach) ||
        (titan.faceDir === -1 &&
          playerCenterX <= titanCenterX - 2 &&
          playerCenterX >= titanCenterX - titanFrontReach);

      return inFront && inVerticalRange;
    }

    document.addEventListener("keydown", (e) => {
      const key = e.key.toLowerCase();
      keys[key] = true;

      const jumpPressed = (key === "w" || e.key === "ArrowUp");
      const attackPressed = (e.code === "Space");

      if (jumpPressed && game.state === "playing" && player.onGround) {
        player.vy = player.jumpPower;
        player.onGround = false;
      }

      if (attackPressed && game.state === "playing" && player.attackCooldown <= 0) {
        player.attackTimer = 10;
        player.attackCooldown = 16;
      }

      if (key === "r") {
        resetGame();
      }
    });

    document.addEventListener("keyup", (e) => {
      const key = e.key.toLowerCase();
      keys[key] = false;
    });

    canvas.addEventListener("mousedown", (e) => {
  if (game.state !== "playing") return;
  if (player.gas <= 0) return;

  const rect = canvas.getBoundingClientRect();
  const clickX = e.clientX - rect.left;
  const clickY = e.clientY - rect.top;
  const worldX = clickX + camera.x;
  const worldY = clickY;

  startGrapple({
    x: worldX,
    y: worldY
  });
});

document.addEventListener("mouseup", () => {
  if (player.grappling) {
    player.grappling = false;
    player.grappleTarget = null;
  }
});

    function updateTimers() {
      if (player.boostMode) {
        player.boostTimer--;
        if (player.boostTimer <= 0) {
          player.boostMode = false;
        }
      }

      if (player.attackTimer > 0) player.attackTimer--;
      if (player.attackCooldown > 0) player.attackCooldown--;
      if (player.hitFlashTimer > 0) player.hitFlashTimer--;
      if (game.invincibleTimer > 0) game.invincibleTimer--;

      titans.forEach(t => {
        if (t.hitCooldown > 0) t.hitCooldown--;
        if (t.attackCooldown > 0) t.attackCooldown--;
        if (t.attackFlashTimer > 0) t.attackFlashTimer--;
        if (t.bloodTimer > 0) t.bloodTimer--;
        if (t.stunTimer > 0) t.stunTimer--;
      });

      updateBloodEffects();
    }

    async function saveScoreToDatabase(){
  if(scoreSaved) return { unlockedTitle: null };
  scoreSaved = true;

  try{
    const res = await fetch("/save-score", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        score: getTotalScore(),
        titanKills: titanKillCount,
        itemsCollected: itemCollectedCount
      })
    });

    const data = await res.json();

    if(data.success && data.unlockedTitle){
      lastUnlockedTitle = data.unlockedTitle;
    }

    return data;
  }catch(err){
    console.log("SAVE SCORE ERROR:", err);
    return { unlockedTitle: null };
  }
}

    function updatePlayer() {
      if (game.state !== "playing") return;

      const moveLeft = keys["a"] || keys["arrowleft"];
      const moveRight = keys["d"] || keys["arrowright"];
      const accel = player.onGround ? 0.62 : 0.30;
      const maxHorizontal = player.boostMode ? 7.0 : player.maxRunSpeed;

      if (moveLeft) {
        player.vx -= accel;
        player.facing = -1;
      }
      if (moveRight) {
        player.vx += accel;
        player.facing = 1;
      }

      if (!moveLeft && !moveRight && player.onGround) {
        player.vx *= player.groundFriction;
      }

      if (!player.onGround) {
        player.vx *= player.airFriction;
      }

      player.vx = clamp(player.vx, -maxHorizontal, maxHorizontal);

      if (player.grappling && player.grappleTarget) {
        const px = player.x + player.width / 2;
        const py = player.y + player.height / 2;
        const tx = player.grappleTarget.x;
        const ty = player.grappleTarget.y;

        const dx = tx - px;
        const dy = ty - py;
        const length = Math.max(1, Math.sqrt(dx * dx + dy * dy));
        const nx = dx / length;
        const ny = dy / length;

        player.vx += nx * player.grapplePull;
        player.vy += ny * player.grapplePull;

        if (length < 34) {
          player.vx += 2.3 * player.facing;
          player.vy -= 1.4;
          player.grappling = false;
          player.grappleTarget = null;
        }
      }

      player.vy += player.gravity;
      player.vx = clamp(player.vx, -11, 11);
      player.vy = clamp(player.vy, -16, 15);

      const prevY = player.y;
      player.x += player.vx;
      player.y += player.vy;

      if (player.x < 0) {
        player.x = 0;
        player.vx = 0;
      }
      if (player.x + player.width > WORLD.width) {
        player.x = WORLD.width - player.width;
        player.vx = 0;
      }

      player.onGround = false;

      if (player.y + player.height >= ground.y) {
        player.y = ground.y - player.height;
        player.vy = 0;
        player.onGround = true;
      }

      const standables = itemSlots.map(slot => ({
  x: slot.x - 25,
  y: slot.y + 18,
  width: 70,
  height: 12
}));

      for (const s of standables) {
        const playerRect = getPlayerRect();

        if (rectsCollide(playerRect, s)) {
          const prevBottom = prevY + player.height;
          const currBottom = player.y + player.height;

          if (prevBottom <= s.y + 8 && currBottom >= s.y) {
            player.y = s.y - player.height;
            player.vy = 0;
            player.onGround = true;
          }
        }
      }

      if (player.y > canvas.height + 220) {
        setLose("Düştün!");
      }

      if (player.x > game.maxProgressX) {
        game.maxProgressX = player.x;
      }
    }

    function updateTitans() {
      if (game.state !== "playing") return;

      titans.forEach(titan => {
        if (!titan.alive) return;

        if (titan.stunTimer <= 0) {
          titan.x += titan.dir * titan.moveSpeed;
          if (titan.x <= titan.minX) titan.dir = 1;
          if (titan.x >= titan.maxX) titan.dir = -1;
        }

        titan.faceDir = titan.dir;

        if (player.attackTimer > 0) {
          attackTitanIfPossible(titan);
        }

        const titanRect = {
          x: titan.x,
          y: titan.y,
          width: titan.width,
          height: titan.height
        };

        if (rectsCollide(getPlayerRect(), titanRect)) {
          if (titan.stunTimer <= 0 && titanCanAttackPlayer(titan) && titan.attackCooldown <= 0) {
            damagePlayer(titan.damage, titan.x + titan.width / 2);
            titan.attackCooldown = 40;
            titan.attackFlashTimer = 12;
          }
        }
      });
    }

    function updateItems() {
      if (game.state !== "playing") return;

      items.forEach(item => {
        if (item.collected) return;

        const itemRect = {
          x: item.x,
          y: item.y,
          width: item.width,
          height: item.height
        };

        if (rectsCollide(getPlayerRect(), itemRect)) {
          item.collected = true;
          itemScore += item.score;
          itemCollectedCount++;
          if (item.kind === "gas") {
            collectedSupplyCount++;
          }

          updateObjectiveProgress();


          if (item.kind === "boost") {
            player.boostMode = true;
            player.boostTimer = 520;
            player.vx += 1.5 * player.facing;
            player.vy -= 1.5;
          } else if (item.kind === "medkit") {
            player.health = Math.min(player.maxHealth, player.health + item.heal);
          } else if (item.kind === "gas") {
            player.gas = Math.min(player.maxGas, player.gas + item.gas);
          }
        }
      });
    }

    async function updateFinish() {
  if (game.state !== "playing") return;

  const finishRect = {
    x: finish.x,
    y: finish.y,
    width: finish.width,
    height: finish.height
  };

  if (rectsCollide(getPlayerRect(), finishRect)) {
  if (objectiveType === "reach") {
    const progressEl = document.getElementById("objectiveProgress");
    const completeBtn = document.getElementById("completeSectorBtn");

    if (progressEl) {
      progressEl.textContent = "COMPLETED";
    }

    if (completeBtn) {
      completeBtn.style.display = "block";
    }
  }
}
}

    function updateCamera() {
      camera.x = player.x - canvas.width * 0.42;
      camera.x = clamp(camera.x, 0, WORLD.width - canvas.width);
    }

    function drawSky() {
  if (levelBackground.complete && levelBackground.naturalWidth > 0) {
    const parallax = 1.0;

    ctx.drawImage(
      levelBackground,
      -camera.x * parallax,
      0,
      WORLD.width,
      canvas.height
    );

    ctx.fillStyle = "rgba(0,0,0,0.20)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    return;
  }

  ctx.fillStyle = "#0a1018";
  ctx.fillRect(0, 0, canvas.width, canvas.height);
}

    function drawGround() {
      ctx.fillStyle = "rgba(255,255,220,0.08)";
      ctx.fillRect(ground.x - camera.x, ground.y, ground.width, ground.height);

      ctx.fillStyle = "rgba(75, 95, 55, 0.55)";
      ctx.fillRect(ground.x - camera.x, ground.y, ground.width, 8);
    }
    

    function drawPlatforms() {
  itemSlots.forEach(slot => {
    const x = slot.x - camera.x - 25;
    const y = slot.y + 22;

    ctx.fillStyle = "#5b341c";
    ctx.fillRect(x, y, 70, 10);

    ctx.fillStyle = "#8b5a2b";
    ctx.fillRect(x, y - 4, 70, 5);

    ctx.strokeStyle = "rgba(0,0,0,0.45)";
    ctx.strokeRect(x, y - 4, 70, 15);
  });
}
    


    function drawItems() {
      items.forEach(item => {
        if (item.collected) return;

        const drawX = item.x - camera.x;
        const drawY = item.y;

        if (item.kind === "boost") {
          ctx.fillStyle = "#00d8ff";
          ctx.beginPath();
          ctx.arc(drawX + 9, drawY + 9, 9, 0, Math.PI * 2);
          ctx.fill();
        } else if (item.kind === "medkit") {
          ctx.fillStyle = "#ffffff";
          ctx.fillRect(drawX, drawY, 18, 18);
          ctx.fillStyle = "#e74c3c";
          ctx.fillRect(drawX + 7, drawY + 3, 4, 12);
          ctx.fillRect(drawX + 3, drawY + 7, 12, 4);
        } else if (item.kind === "gas") {
          ctx.fillStyle = "#bfc7cf";
          ctx.fillRect(drawX + 4, drawY + 2, 10, 14);
          ctx.fillStyle = "#6f7a84";
          ctx.fillRect(drawX + 6, drawY, 6, 4);
          ctx.strokeStyle = "#ffffff";
          ctx.strokeRect(drawX + 4, drawY + 2, 10, 14);
        } else {
          ctx.fillStyle = "#f1c40f";
          ctx.beginPath();
          ctx.arc(drawX + 9, drawY + 9, 8, 0, Math.PI * 2);
          ctx.fill();
        }

        ctx.strokeStyle = "rgba(255,255,255,0.8)";
        ctx.lineWidth = 2;
        ctx.strokeRect(drawX - 1, drawY - 1, 20, 20);
      });
    }

    function drawTitans() {
      titans.forEach(titan => {
        if (!titan.alive) return;

        const x = titan.x - camera.x;
        const y = titan.y;

        ctx.fillStyle = titan.isBoss ? (titan.hitCooldown > 0 ? "#b13b3b" : "#7f1d1d") : (titan.hitCooldown > 0 ? "#e9897f" : "#c96a5d");
        ctx.fillRect(x, y, titan.width, titan.height);

        ctx.fillStyle = "rgba(120,0,0,0.25)";
        ctx.fillRect(x + titan.width * 0.12, y + titan.height * 0.12, titan.width * 0.76, titan.height * 0.26);

        ctx.fillStyle = "#8b2d2d";
        ctx.fillRect(x + 6, y + 12, titan.width - 12, 10);

        ctx.fillStyle = "#fff";
        ctx.fillRect(x + 8, y + 22, 7, 7);
        ctx.fillRect(x + titan.width - 15, y + 22, 7, 7);

        ctx.fillStyle = titan.attackFlashTimer > 0 ? "#ffb3a8" : "#b85b4e";
        if (titan.faceDir === 1) {
          ctx.fillRect(x + titan.width - 3, y + titan.height * 0.45, titan.width * 0.42, 10);
        } else {
          ctx.fillRect(x - titan.width * 0.42 + 3, y + titan.height * 0.45, titan.width * 0.42, 10);
        }

        if (titan.bloodTimer > 0) {
          ctx.fillStyle = "rgba(180,0,0,0.75)";
          ctx.beginPath();
          ctx.arc(x + titan.width / 2, y + titan.height * 0.23, 7, 0, Math.PI * 2);
          ctx.fill();
        }

        if (titan.stunTimer > 0) {
          ctx.fillStyle = "#ffd54f";
          ctx.beginPath();
          ctx.arc(x + titan.width / 2, y - 20, 4, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(x + titan.width / 2 - 10, y - 13, 4, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(x + titan.width / 2 + 10, y - 13, 4, 0, Math.PI * 2);
          ctx.fill();
        }

        const barWidth = titan.width;
        const healthRatio = Math.max(0, titan.health / titan.maxHealth);

        ctx.fillStyle = "rgba(0,0,0,0.45)";
        ctx.fillRect(x, y - 12, barWidth, 6);

        ctx.fillStyle = "#2ecc71";
        ctx.fillRect(x, y - 12, barWidth * healthRatio, 6);

        if (titan.isBoss) {
          ctx.fillStyle = "#f1c40f";
          ctx.font = "bold 12px Arial";
          ctx.fillText("BOSS", x, y - 20);
        }
      });
    }

    function drawFinish() {
  if (objectiveType !== "reach") return;

  const drawX = finish.x - camera.x;
  const drawY = finish.y;

  // Ana kolon
  ctx.fillStyle = "#00bfff";
  ctx.fillRect(drawX, drawY, finish.width, finish.height);

  // Parlayan dış çizgi
  ctx.strokeStyle = "#ffffff";
  ctx.lineWidth = 3;
  ctx.strokeRect(drawX, drawY, finish.width, finish.height);

  // Üst işaret
  ctx.fillStyle = "#ffffff";
  ctx.font = "bold 16px Arial";
  ctx.fillText("Inner Wall", drawX - 8, drawY - 10);

  // Hedef halkası
  ctx.beginPath();
  ctx.arc(drawX + finish.width / 2, drawY + finish.height / 2, 35, 0, Math.PI * 2);
  ctx.strokeStyle = "rgba(0,255,150,0.8)";
  ctx.lineWidth = 3;
  ctx.stroke();
}

    function drawGrappleLine() {
      if (!player.grappling || !player.grappleTarget) return;

      const px = player.x + player.width / 2 - camera.x;
      const py = player.y + player.height / 2;
      const tx = player.grappleTarget.x - camera.x;
      const ty = player.grappleTarget.y;

      ctx.strokeStyle = "#e5e5e5";
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(px, py);
      ctx.lineTo(tx, ty);
      ctx.stroke();

      ctx.fillStyle = "#9ae8ff";
      ctx.beginPath();
      ctx.arc(tx, ty, 4, 0, Math.PI * 2);
      ctx.fill();
    }

    function drawBloodEffects() {
      for (const p of bloodEffects) {
        ctx.fillStyle = "rgba(160,0,0,0.9)";
        ctx.beginPath();
        ctx.arc(p.x - camera.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function drawPlayer() {
      const x = player.x - camera.x;
      const y = player.y;

      if (game.invincibleTimer > 0 && Math.floor(game.invincibleTimer / 4) % 2 === 0) {
        ctx.globalAlpha = 0.45;
      }

      ctx.fillStyle = player.boostMode ? "#f1c40f" : "#2ecc71";
      ctx.fillRect(x, y, player.width, player.height);

      ctx.fillStyle = "#ffffff";
      ctx.fillRect(x + 6, y + 10, 5, 4);
      ctx.fillRect(x + 17, y + 10, 5, 4);

      ctx.fillStyle = "#cfd8dc";
      if (player.facing === 1) {
        ctx.fillRect(x + player.width, y + 18, 10, 3);
      } else {
        ctx.fillRect(x - 10, y + 18, 10, 3);
      }

      if (player.attackTimer > 0) {
        const slashX = player.facing === 1 ? x + player.width + 2 : x - 28;
        const slashY = y + 10;

        ctx.strokeStyle = player.boostMode ? "rgba(0,216,255,0.95)" : "rgba(255,255,255,0.9)";
        ctx.lineWidth = player.boostMode ? 4 : 3;
        ctx.beginPath();
        if (player.facing === 1) {
          ctx.moveTo(slashX, slashY + 14);
          ctx.lineTo(slashX + 28, slashY);
        } else {
          ctx.moveTo(slashX + 28, slashY + 14);
          ctx.lineTo(slashX, slashY);
        }
        ctx.stroke();
      }

      if (player.hitFlashTimer > 0) {
        ctx.strokeStyle = "rgba(255,120,120,0.9)";
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(x + player.width / 2, y + player.height / 2, 24, 0, Math.PI * 2);
        ctx.stroke();
      }

      ctx.globalAlpha = 1;
    }

    function drawHUD() {
  scoreText.textContent = "Score: " + getTotalScore();

  ctx.fillStyle = "rgba(0,0,0,0.35)";
  ctx.fillRect(10, 10, 320, 210);

  ctx.fillStyle = "#fff";
  ctx.font = "16px Arial";
  ctx.fillText("Kill: " + killScore, 20, 34);
  ctx.fillText("Item: " + itemScore, 20, 58);
  ctx.fillText("Distance: " + getDistanceScore(), 20, 82);

  ctx.fillStyle = "white";
  ctx.fillText("Can:", 20, 115);

  ctx.fillStyle = "rgba(255,255,255,0.2)";
  ctx.fillRect(65, 102, 150, 16);

  ctx.fillStyle = player.health > 55 ? "#2ecc71" : player.health > 25 ? "#f1c40f" : "#e74c3c";
  ctx.fillRect(65, 102, 150 * (player.health / player.maxHealth), 16);

  ctx.strokeStyle = "rgba(255,255,255,0.7)";
  ctx.strokeRect(65, 102, 150, 16);

  ctx.fillStyle = "white";
  ctx.fillText("Gaz:", 20, 145);

  ctx.fillStyle = "rgba(255,255,255,0.2)";
  ctx.fillRect(65, 132, 150, 16);

  ctx.fillStyle = "#66ccff";
  ctx.fillRect(65, 132, 150 * (player.gas / player.maxGas), 16);

  ctx.strokeStyle = "rgba(255,255,255,0.7)";
  ctx.strokeRect(65, 132, 150, 16);

  if (player.boostMode) {
    ctx.fillStyle = "#00d8ff";
    ctx.fillText("ODM Boost: " + player.boostTimer, 20, 176);
  }

      if (player.gas <= 0) {
        ctx.fillStyle = "#ff8080";
        ctx.fillText("Gaz bitti!", 180, 138);
      }
    }

    function drawGameMessage() {
      if (game.state === "playing") return;

      ctx.fillStyle = "rgba(0,0,0,0.62)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.fillStyle = "#fff";
      ctx.textAlign = "center";
      ctx.font = "bold 38px Arial";
      ctx.fillText(game.state === "win" ? "KAZANDIN!" : "OYUN BİTTİ", canvas.width / 2, 220);

      ctx.font = "24px Arial";
      ctx.fillText(game.message, canvas.width / 2, 270);

      ctx.font = "22px Arial";
      ctx.fillText("Toplam Skor: " + getTotalScore(), canvas.width / 2, 320);

      ctx.font = "18px Arial";
      ctx.fillText("Tekrar başlamak için R tuşuna bas", canvas.width / 2, 370);
      ctx.textAlign = "start";
    }

    function update() {
      updateTimers();
      updatePlayer();
      updateTitans();
      updateItems();
      updateFinish();
      updateCamera();
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      drawSky();
      drawPlatforms();
      drawGround();
      drawItems();
      drawTitans();
      drawFinish();
      drawBloodEffects();
      drawGrappleLine();
      drawPlayer();
      drawHUD();
      drawGameMessage();
    }

    function gameLoop() {
      update();
      draw();
      requestAnimationFrame(gameLoop);
    }

    const gameMeta = document.getElementById("gameMeta");
    const objectiveType = gameMeta.dataset.objectiveType || "kill";
    const targetKillCount = Number(gameMeta.dataset.targetKillCount || 0);
    const targetItemCount = Number(gameMeta.dataset.targetItemCount || 0);
    const spawnEnemyCount = Number(gameMeta.dataset.spawnEnemyCount || targetKillCount);
    const spawnGasCount = Number(gameMeta.dataset.spawnGasCount || 2);
    const currentBattle = Number(gameMeta.dataset.level || 1);
    const currentSectorNumber = Number(gameMeta.dataset.sector || 1);

    function updateObjectiveProgress() {
  const progressEl = document.getElementById("objectiveProgress");
  const completeBtn = document.getElementById("completeSectorBtn");

  if (!progressEl || !completeBtn) return;

  if (objectiveType === "kill") {
    progressEl.textContent = `${titanKillCount} / ${targetKillCount}`;

    if (titanKillCount >= targetKillCount) {
      progressEl.textContent = "COMPLETED";
      completeBtn.style.display = "block";
    }
  }

  else if (objectiveType === "collect") {
    progressEl.textContent = `${collectedSupplyCount} / ${targetItemCount}`;

    if (collectedSupplyCount >= targetItemCount) {
      progressEl.textContent = "COMPLETED";
      completeBtn.style.display = "block";
    }
  }

  else if (objectiveType === "reach") {
    progressEl.textContent = "NOT REACHED";
  }
}

    resetGame();
    updateObjectiveProgress();
    gameLoop();
  </script>

<script>
  const completeSectorBtn = document.getElementById("completeSectorBtn");

  if (completeSectorBtn) {
    completeSectorBtn.addEventListener("click", async () => {
      try {
        const url = `/game/<%= level %>/<%= sector %>/complete`;
        console.log("POST URL:", url);

        const response = await fetch(url, {
  method: "POST",
  headers: {
    "Content-Type": "application/json"
  },
  body: JSON.stringify({
    score: getTotalScore(),
    titanKills: titanKillCount,
    itemsCollected: itemCollectedCount
  })
});

        console.log("Response status:", response.status);

        const rawText = await response.text();
        console.log("Raw response:", rawText);

        let data;
        try {
          data = JSON.parse(rawText);
        } catch (e) {
          alert("Server valid JSON döndürmedi. Console'a bak.");
          return;
        }

        if (!data.success) {
          alert(data.message || "Sector could not be completed.");
          return;
        }

        alert(`Sector completed! Reward: ${data.reward}`);
        window.location.href = `/game/${data.nextLevel}/${data.nextSector}`;
      } catch (error) {
        console.error("Complete sector request failed:", error);
        alert("Complete sector request failed. Console'a bak.");
      }
    });
  
  }


</script>



</body>
</html>