<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Main Menu</title>

  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;800&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      width:100vw;
      height:100vh;
      overflow:hidden;
      background:#111;
      font-family:"Libre Baskerville", serif;
    }

    body.page-leaving .screen-fade{
      opacity:1;
      pointer-events:auto;
    }

    body.page-leaving .left-side{
      opacity:0;
      transform:translateY(-50%) translateX(-14px) scale(0.98);
    }

    body.page-leaving .right-menu{
      opacity:0;
      transform:translateY(-50%) translateX(18px) scale(0.98);
    }

    .menu-container{
      position:relative;
      width:100%;
      height:100%;
      background:url("/images/map-menu.png") center/cover no-repeat;
      isolation:isolate;
    }

    .menu-container::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at center,
          rgba(0,0,0,0) 34%,
          rgba(0,0,0,0.20) 70%,
          rgba(0,0,0,0.34) 100%);
      z-index:1;
      pointer-events:none;
    }

    .menu-container::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(rgba(0,0,0,0.14), rgba(0,0,0,0.14)),
        linear-gradient(rgba(120,90,40,0.05), rgba(120,90,40,0.05));
      z-index:1;
      pointer-events:none;
    }

    .screen-fade{
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at center, rgba(24,18,12,0.08), rgba(14,10,7,0.92));
      opacity:0;
      transition:opacity 0.35s ease;
      pointer-events:none;
      z-index:100;
    }

    .notification-stack{
      position:absolute;
      top:18px;
      left:50%;
      transform:translateX(-50%);
      z-index:40;
      display:flex;
      flex-direction:column;
      gap:10px;
      align-items:center;
    }

    .notify{
      min-width:240px;
      max-width:420px;
      padding:11px 15px;
      border-radius:12px;
      font-weight:700;
      color:#fff;
      text-align:center;
      box-shadow:0 10px 24px rgba(0,0,0,0.25);
      backdrop-filter:blur(6px);
      -webkit-backdrop-filter:blur(6px);
      font-size:14px;
    }

    .notify.unlock{
      background:rgba(30, 144, 255, 0.28);
      border:1px solid rgba(255,255,255,0.18);
    }

    .notify.levelup{
      background:rgba(76, 175, 80, 0.28);
      border:1px solid rgba(255,255,255,0.18);
    }

    .parchment-panel{
      position:absolute;
      z-index:10;
      overflow:hidden;
      color:#4c3922;
      background:
        radial-gradient(circle at center, rgba(255,245,220,0.55), transparent 60%),
        linear-gradient(
          180deg,
          rgba(236,224,195,0.95) 0%,
          rgba(229,216,188,0.95) 45%,
          rgba(220,205,176,0.95) 100%
        );
      border:1px solid rgba(140,110,70,0.24);
      border-radius:10px;
      box-shadow:
        0 16px 30px rgba(0,0,0,0.18),
        inset 0 0 22px rgba(110,86,52,0.07),
        inset 0 1px 0 rgba(255,255,255,0.34);
      backdrop-filter:blur(2px);
      -webkit-backdrop-filter:blur(2px);
      filter:saturate(0.95) contrast(0.985);
    }

    .parchment-panel::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        url("/images/parchment-texture.jpg") center/cover no-repeat,
        radial-gradient(circle at 20% 15%, rgba(255,255,255,0.13), transparent 28%),
        radial-gradient(circle at 80% 70%, rgba(120,90,55,0.06), transparent 32%);
      opacity:0.55;
      mix-blend-mode:multiply;
      pointer-events:none;
    }

    .parchment-panel::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 0% 50%, rgba(0,0,0,0.18), transparent 29%),
        radial-gradient(circle at 100% 50%, rgba(0,0,0,0.18), transparent 29%),
        linear-gradient(to bottom, rgba(120,90,50,0.08), transparent 10%, transparent 90%, rgba(120,90,50,0.08));
      opacity:0.55;
      mix-blend-mode:multiply;
      pointer-events:none;
    }

    .parchment-lip-top,
    .parchment-lip-bottom{
      position:absolute;
      left:18px;
      right:18px;
      height:13px;
      border-radius:999px;
      z-index:12;
      background:
        linear-gradient(
          180deg,
          #d6b47a 0%,
          #b88a4c 60%,
          #a6783e 100%
        );
      box-shadow:
        0 2px 6px rgba(0,0,0,0.18),
        inset 0 1px 0 rgba(255,255,255,0.24),
        inset 0 -2px 4px rgba(0,0,0,0.13);
      pointer-events:none;
    }

    .parchment-lip-top{ top:-2px; }
    .parchment-lip-bottom{ bottom:-2px; }

    .left-side{
      position:absolute;
      left:30px;
      top:50%;
      transform:translateY(-50%);
      width:270px;
      z-index:12;
      display:flex;
      flex-direction:column;
      gap:16px;
      animation:fadeLeft 0.6s ease;
      transition:opacity 0.28s ease, transform 0.28s ease;
    }

    .left-card{
      position:relative;
      padding:18px 16px 16px;
    }

    .profile-card{ min-height:198px; }
    .objective-card{ min-height:248px; }

    .left-card-content,
    .right-menu-content{
      position:relative;
      z-index:14;
    }

    .left-card-title,
    .player-name,
    .menu-title{
      font-family:"Cinzel", serif;
      text-shadow:
        0 1px 0 rgba(255,255,255,0.35),
        0 2px 2px rgba(0,0,0,0.12);
      color:#5a4125;
    }

    .left-card-title{
      font-size:20px;
      font-weight:800;
      margin-bottom:14px;
      letter-spacing:0.3px;
      line-height:1.2;
    }

    .left-card-title::after,
    .menu-title::after{
      content:"";
      display:block;
      width:46px;
      height:1px;
      background:rgba(120,90,50,0.35);
      margin-top:8px;
    }

    .profile-row{
      display:flex;
      align-items:center;
      gap:12px;
      margin-bottom:13px;
    }

    .avatar-box{
      width:92px;
      height:92px;
      border-radius:10px;
      overflow:hidden;
      border:1px solid rgba(150,120,75,0.40);
      background:rgba(255,255,255,0.16);
      flex-shrink:0;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:
        0 4px 10px rgba(0,0,0,0.12),
        inset 0 1px 0 rgba(255,255,255,0.25);
    }

    .avatar-box img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .avatar-placeholder{
      font-size:34px;
    }

    .profile-meta{
      min-width:0;
    }

    .profile-name{
      font-size:16px;
      font-weight:800;
      margin-bottom:6px;
      line-height:1.2;
    }

    .profile-title{
      font-size:12px;
      line-height:1.45;
      color:#6a5130;
    }

    .profile-title span{
      color:#549db8;
      font-weight:800;
    }

    .stat-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:9px;
      margin-top:10px;
    }

    .stat-box{
      padding:9px 11px;
      border-radius:10px;
      background:rgba(255,255,255,0.14);
      border:1px solid rgba(135,106,69,0.15);
      box-shadow:inset 0 1px 0 rgba(255,255,255,0.20);
    }

    .stat-label{
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:0.7px;
      color:#7a6140;
      margin-bottom:4px;
    }

    .stat-value{
      font-size:15px;
      font-weight:800;
      color:#5a4125;
      font-family:"Cinzel", serif;
    }

    .objective-list{
      padding-left:20px;
      line-height:1.8;
      color:#5e4728;
      font-size:12px;
      font-weight:600;
    }

    .objective-list li{
      margin-bottom:4px;
    }

    .objective-note{
      margin-top:12px;
      font-size:11.5px;
      line-height:1.55;
      color:#7a6241;
    }

    .right-menu{
      top:52%;
      right:48px;
      transform:translateY(-50%);
      width:318px;
      padding:22px 16px 18px;
      animation:fadeRight 0.6s ease;
      transition:opacity 0.28s ease, transform 0.28s ease;
    }

    .menu-top{
      margin-bottom:22px;
      padding-bottom:18px;
      border-bottom:1px solid rgba(130,100,60,0.18);
    }

    .player-name{
      font-size:18px;
      font-weight:800;
      margin-bottom:9px;
      line-height:1.25;
    }

    .player-title{
      font-size:11.5px;
      margin-bottom:8px;
      color:#7a6241;
      line-height:1.45;
      text-transform:uppercase;
      letter-spacing:0.35px;
    }

    .player-title span{
      color:#549db8;
      font-weight:800;
      text-transform:none;
      letter-spacing:0;
    }

    .player-level{
      font-size:17px;
      font-weight:700;
      margin-bottom:11px;
      color:#5a4125;
      font-family:"Cinzel", serif;
    }

    .progress-wrapper{
      margin-bottom:10px;
    }

    .progress-bar{
      width:100%;
      height:13px;
      border-radius:999px;
      overflow:hidden;
      background:rgba(126,98,61,0.14);
      border:1px solid rgba(126,98,61,0.08);
    }

    .progress{
      height:100%;
      border-radius:999px;
      background:linear-gradient(90deg, #30c8f7, #49a7ff);
      transition:width 0.4s ease;
      box-shadow:0 0 10px rgba(73,167,255,0.20);
    }

    .score-row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      font-size:11.5px;
      color:#7b6241;
    }

    .gift-area{
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .gift-icon{
      font-size:21px;
      cursor:pointer;
      user-select:none;
      transition:transform 0.2s ease;
    }

    .gift-area:hover .gift-icon{
      transform:scale(1.12);
    }

    .progress-tooltip{
      position:absolute;
      right:0;
      bottom:34px;
      width:210px;
      padding:10px 11px;
      border-radius:12px;
      background:rgba(68,50,28,0.96);
      color:#f6ead1;
      font-size:11.5px;
      line-height:1.5;
      box-shadow:0 10px 20px rgba(0,0,0,0.20);
      opacity:0;
      transform:translateY(6px);
      pointer-events:none;
      transition:0.2s ease;
      text-align:left;
      z-index:30;
      font-family:"Libre Baskerville", serif;
    }

    .gift-area:hover .progress-tooltip{
      opacity:1;
      transform:translateY(0);
    }

    .menu-title{
      text-align:center;
      font-size:25px;
      font-weight:800;
      margin-bottom:14px;
      letter-spacing:0.6px;
    }

    .menu-title::after{
      margin-left:auto;
      margin-right:auto;
    }

    .menu-link{
      display:block;
      width:100%;
      text-decoration:none;
      text-align:center;
      color:#5a4125;
      font-size:14px;
      font-weight:700;
      font-family:"Cinzel", serif;
      padding:12px;
      margin-bottom:10px;
      border-radius:10px;
      background:
        linear-gradient(
          180deg,
          rgba(255,250,240,0.52),
          rgba(245,235,210,0.42)
        );
      border:1px solid rgba(120,90,50,0.22);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.35),
        0 1px 2px rgba(0,0,0,0.05);
      transition:all 0.18s ease;
      position:relative;
      z-index:14;
      letter-spacing:0.2px;
      cursor:pointer;
    }

    .menu-link:hover{
      background:
        linear-gradient(
          180deg,
          rgba(255,252,245,0.72),
          rgba(245,235,210,0.62)
        );
      transform:translateY(-2px) scale(1.01);
      box-shadow:
        0 0 0 1px rgba(200,160,90,0.28),
        0 6px 14px rgba(0,0,0,0.08),
        inset 0 1px 0 rgba(255,255,255,0.30);
    }

    .menu-link:active{
      transform:scale(0.97);
      box-shadow:inset 0 2px 4px rgba(0,0,0,0.18);
    }

    .menu-link.logout{
      margin-top:2px;
    }

    @keyframes fadeRight{
      from{
        opacity:0;
        transform:translateY(-45%) translateX(14px) scale(0.97);
      }
      to{
        opacity:1;
        transform:translateY(-50%) translateX(0) scale(1);
      }
    }

    @keyframes fadeLeft{
      from{
        opacity:0;
        transform:translateY(-45%) translateX(-12px) scale(0.97);
      }
      to{
        opacity:1;
        transform:translateY(-50%) translateX(0) scale(1);
      }
    }

    @media (max-width: 1180px){
      .left-side{
        width:252px;
        left:20px;
      }

      .right-menu{
        width:302px;
        right:24px;
      }
    }

    @media (max-width: 980px){
      .left-side{
        display:none;
      }

      .right-menu{
        right:26px;
        width:320px;
      }
    }

    @media (max-width: 700px){
      .right-menu{
        left:50%;
        right:auto;
        top:52%;
        transform:translate(-50%, -50%);
        width:min(92vw, 340px);
        animation:none;
      }

      .notification-stack{
        width:92%;
      }

      .notify{
        width:100%;
        min-width:unset;
      }
    }
  </style>
</head>
<body>

<%
  const safeProgress = isNaN(progress) ? 0 : progress;
  const progressPercent = Math.max(0, Math.min(100, safeProgress * 100)).toFixed(2);

  const currentCharacter = user.selectedCharacter || "Eren Yeager";
  const avatarSrc = user.avatar || "";
%>

<div class="menu-container">

  <div class="notification-stack">
    <% if(titleUnlocked){ %>
      <div class="notify unlock">🎉 <%= titleUnlocked %></div>
    <% } %>

    <% if(levelUp){ %>
      <div class="notify levelup">⭐ <%= levelUp %></div>
    <% } %>
  </div>

  <div class="left-side">

    <div class="parchment-panel left-card profile-card">
      <div class="parchment-lip-top"></div>
      <div class="parchment-lip-bottom"></div>

      <div class="left-card-content">
        <div class="left-card-title">🛡️ Scout Profile</div>

        <div class="profile-row">
          <div class="avatar-box">
            <% if (avatarSrc) { %>
              <img src="<%= avatarSrc %>" alt="Avatar">
            <% } else { %>
              <div class="avatar-placeholder">🛡️</div>
            <% } %>
          </div>

          <div class="profile-meta">
            <div class="profile-name"><%= user.username %></div>
            <div class="profile-title">
              Title: <span><%= user.title %></span><br>
              Character: <strong><%= currentCharacter %></strong>
            </div>
          </div>
        </div>

        <div class="stat-grid">
          <div class="stat-box">
            <div class="stat-label">Level</div>
            <div class="stat-value"><%= level %></div>
          </div>

          <div class="stat-box">
            <div class="stat-label">Score</div>
            <div class="stat-value"><%= user.totalScore %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="parchment-panel left-card objective-card">
      <div class="parchment-lip-top"></div>
      <div class="parchment-lip-bottom"></div>

      <div class="left-card-content">
        <div class="left-card-title">📜 Current Objective</div>

        <ul class="objective-list">
          <li>Continue the expedition</li>
          <li>Defeat titans for score</li>
          <li>Collect supplies</li>
          <li>Unlock the next reward</li>
        </ul>

        <div class="objective-note">
          The fate of humanity depends on your progress beyond the walls.
        </div>
      </div>
    </div>

  </div>

  <div class="parchment-panel right-menu">
    <div class="parchment-lip-top"></div>
    <div class="parchment-lip-bottom"></div>

    <div class="right-menu-content">
      <div class="menu-top">
        <div class="player-name">
          Welcome, <%= user.username %>
        </div>

        <div class="player-title">
          Current Title: <span><%= user.title %></span>
        </div>

        <div class="player-level">
          Level <%= level %>
        </div>

        <div class="progress-wrapper">
          <div class="progress-bar">
            <div class="progress" style="width:<%= progressPercent %>%;"></div>
          </div>
        </div>

        <div class="score-row">
          <span><%= user.totalScore %> / <%= nextLevel %> score</span>

          <div class="gift-area">
            <div class="gift-icon">🎁</div>

            <div class="progress-tooltip">
              <strong>Next Level Rewards:</strong><br>
              <% nextLevelRewards.forEach(r => { %>
                • <%= r %><br>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <h2 class="menu-title">Main Menu</h2>

      <a class="menu-link" href="/map">Start Game</a>
      <a class="menu-link" href="/profile">My Profile</a>
      <a class="menu-link" href="/account">My Account</a>
      <a class="menu-link" href="/leaderboard">Leaderboard</a>
      <a class="menu-link" href="/market">Market</a>
      <a class="menu-link" href="/how-to-play">How to Play</a>
      <a class="menu-link" href="/titles">Titles</a>
      <a class="menu-link logout" href="/logout">Logout</a>
    </div>
  </div>

  <div class="screen-fade"></div>

  <audio id="menuHoverSound" preload="auto">
    <source src="/sounds/menu-hover.wav" type="audio/wav">
  </audio>

  <audio id="menuClickSound" preload="auto">
    <source src="/sounds/menu-click.wav" type="audio/wav">
  </audio>

</div>

<script>
  const hoverSound = document.getElementById("menuHoverSound");
  const clickSound = document.getElementById("menuClickSound");
  const menuLinks = document.querySelectorAll(".menu-link");
  let hoverUnlocked = false;
  let leaving = false;

  function safePlay(audio, volume = 0.35) {
    if (!audio) return;
    try {
      audio.pause();
      audio.currentTime = 0;
      audio.volume = volume;
      const p = audio.play();
      if (p && typeof p.catch === "function") p.catch(() => {});
    } catch (_) {}
  }

  function unlockAudio() {
    if (hoverUnlocked) return;
    hoverUnlocked = true;
    [hoverSound, clickSound].forEach(audio => {
      if (!audio) return;
      audio.volume = 0;
      const p = audio.play();
      if (p && typeof p.then === "function") {
        p.then(() => {
          audio.pause();
          audio.currentTime = 0;
          audio.volume = 1;
        }).catch(() => {});
      }
    });
  }

  window.addEventListener("pointerdown", unlockAudio, { once: true });
  window.addEventListener("keydown", unlockAudio, { once: true });

  menuLinks.forEach(link => {
    link.addEventListener("mouseenter", () => {
      if (!hoverUnlocked || leaving) return;
      safePlay(hoverSound, 0.18);
    });

    link.addEventListener("click", (e) => {
      if (leaving) {
        e.preventDefault();
        return;
      }

      const href = link.getAttribute("href");
      if (!href || href.startsWith("#")) return;

      e.preventDefault();
      leaving = true;
      document.body.classList.add("page-leaving");
      safePlay(clickSound, 0.28);

      setTimeout(() => {
        window.location.href = href;
      }, 280);
    });
  });
</script>

</body>
</html>