<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Main Menu</title>

  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      width:100vw;
      height:100vh;
      overflow:hidden;
      background:#111;
      font-family:"Inter", sans-serif;
      color:#f3ede2;
    }

    body.page-leaving .screen-fade{
      opacity:1;
      pointer-events:auto;
    }

    body.page-leaving .left-side{
      opacity:0;
      transform:translateY(-50%) translateX(-14px) scale(0.98);
    }

    body.page-leaving .right-menu{
      opacity:0;
      transform:translateY(-50%) translateX(18px) scale(0.98);
    }

    .menu-container{
      position:relative;
      width:100%;
      height:100%;
      background:url("/images/map-menu.png") center/cover no-repeat;
      isolation:isolate;
    }

    .menu-container::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at center,
          rgba(0,0,0,0) 22%,
          rgba(0,0,0,0.22) 68%,
          rgba(0,0,0,0.44) 100%);
      z-index:1;
      pointer-events:none;
    }

    .menu-container::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(rgba(20,16,12,0.10), rgba(20,16,12,0.10)),
        linear-gradient(rgba(90,70,45,0.03), rgba(90,70,45,0.03));
      z-index:1;
      pointer-events:none;
      animation:mapBreath 8s ease-in-out infinite;
    }

    @keyframes mapBreath{
      0%,100%{opacity:0.08;}
      50%{opacity:0.14;}
    }

    .screen-fade{
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at center, rgba(30,22,16,0.10), rgba(10,8,6,0.94));
      opacity:0;
      transition:opacity 0.35s ease;
      pointer-events:none;
      z-index:100;
    }

    .notification-stack{
      position:absolute;
      top:18px;
      left:50%;
      transform:translateX(-50%);
      z-index:40;
      display:flex;
      flex-direction:column;
      gap:10px;
      align-items:center;
    }

    .notify{
      min-width:240px;
      max-width:420px;
      padding:11px 15px;
      border-radius:14px;
      font-weight:700;
      color:#fff;
      text-align:center;
      box-shadow:0 10px 24px rgba(0,0,0,0.25);
      backdrop-filter:blur(8px);
      -webkit-backdrop-filter:blur(8px);
      font-size:14px;
      border:1px solid rgba(255,255,255,0.12);
    }

    .notify.unlock{
      background:rgba(30, 144, 255, 0.24);
    }

    .notify.levelup{
      background:rgba(76, 175, 80, 0.24);
    }

    .aot-panel{
      position:absolute;
      z-index:10;
      overflow:hidden;
      border-radius:18px;
      background:
        radial-gradient(circle at 50% 20%, rgba(255,246,220,0.12), transparent 38%),
        linear-gradient(180deg, rgba(70,50,26,0.86), rgba(43,31,18,0.90));
      border:1px solid rgba(215,182,112,0.20);
      box-shadow:
        0 18px 34px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,245,220,0.12),
        inset 0 -1px 0 rgba(0,0,0,0.22);
      backdrop-filter:blur(8px);
      -webkit-backdrop-filter:blur(8px);
    }

    .aot-panel::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.05), transparent 18%, transparent 82%, rgba(0,0,0,0.14)),
        repeating-linear-gradient(
          135deg,
          rgba(255,255,255,0.015) 0px,
          rgba(255,255,255,0.015) 2px,
          transparent 2px,
          transparent 16px
        );
      pointer-events:none;
    }

    .aot-panel::after{
      content:"";
      position:absolute;
      inset:8px;
      border:1px solid rgba(232,205,146,0.10);
      border-radius:12px;
      pointer-events:none;
      box-shadow:inset 0 0 18px rgba(0,0,0,0.10);
    }

    .panel-top-strip{
      position:absolute;
      top:0;
      left:20px;
      right:20px;
      height:3px;
      border-radius:999px;
      background:linear-gradient(90deg, rgba(224,190,120,0.0), rgba(224,190,120,0.88), rgba(224,190,120,0.0));
      z-index:3;
      pointer-events:none;
    }

    .panel-bolts{
      position:absolute;
      inset:0;
      pointer-events:none;
      z-index:3;
    }

    .panel-bolts span{
      position:absolute;
      width:10px;
      height:10px;
      border-radius:50%;
      background:
        radial-gradient(circle at 35% 35%, #dcc089, #76562f 72%);
      box-shadow:
        inset 0 1px 1px rgba(255,255,255,0.22),
        0 1px 3px rgba(0,0,0,0.35);
      opacity:0.78;
    }

    .panel-bolts span:nth-child(1){ top:12px; left:12px; }
    .panel-bolts span:nth-child(2){ top:12px; right:12px; }
    .panel-bolts span:nth-child(3){ bottom:12px; left:12px; }
    .panel-bolts span:nth-child(4){ bottom:12px; right:12px; }

    .metal-frame{
      position:absolute;
      inset:0;
      border-radius:18px;
      pointer-events:none;
      z-index:3;
      background:
        linear-gradient(90deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) top / 100% 1px no-repeat,
        linear-gradient(90deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) bottom / 100% 1px no-repeat,
        linear-gradient(180deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) left / 1px 100% no-repeat,
        linear-gradient(180deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) right / 1px 100% no-repeat;
    }

    .panel-rivets{
      position:absolute;
      top:14px;
      bottom:14px;
      right:6px;
      width:6px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      z-index:4;
      pointer-events:none;
    }

    .panel-rivets span{
      width:6px;
      height:6px;
      border-radius:50%;
      background:
        radial-gradient(circle at 30% 30%, #dfc389, #71542c 70%);
      box-shadow:
        inset 0 1px 1px rgba(255,255,255,0.25),
        0 1px 3px rgba(0,0,0,0.5);
      opacity:0.85;
      filter:drop-shadow(0 0 3px rgba(255,220,120,0.16));
    }

    .panel-content{
      position:relative;
      z-index:4;
    }

    .left-side{
      position:absolute;
      left:28px;
      top:50%;
      transform:translateY(-50%);
      width:285px;
      z-index:12;
      display:flex;
      flex-direction:column;
      gap:16px;
      animation:fadeLeft 0.6s ease;
      transition:opacity 0.28s ease, transform 0.28s ease;
    }

    .left-card{
      position:relative;
      padding:18px;
    }

    .profile-card{
      min-height:214px;
    }

    .objective-card{
      min-height:228px;
    }

    .section-title,
    .player-name,
    .menu-title{
      font-family:"Cinzel", serif;
      color:#f4e4bc;
      text-shadow:0 2px 8px rgba(0,0,0,0.28);
    }

    .section-title{
      font-size:20px;
      margin-bottom:14px;
      letter-spacing:0.4px;
    }

    .section-title::after,
    .menu-title::after{
      content:"";
      display:block;
      width:52px;
      height:1px;
      background:rgba(227,197,128,0.50);
      margin-top:8px;
    }

    .profile-row{
      display:flex;
      align-items:flex-start;
      gap:12px;
      margin-bottom:14px;
    }

    .avatar-box{
      width:92px;
      height:92px;
      border-radius:12px;
      overflow:hidden;
      border:1px solid rgba(255,255,255,0.10);
      background:
        linear-gradient(180deg, rgba(255,248,225,0.08), rgba(0,0,0,0.14));
      flex-shrink:0;
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow:
        0 6px 16px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,255,255,0.06);
    }

    .avatar-box img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    .avatar-placeholder{
      font-size:32px;
    }

    .profile-name{
      font-size:17px;
      font-weight:800;
      margin-bottom:6px;
      line-height:1.2;
      color:#f5ecd6;
    }

    .profile-title{
      font-size:12px;
      line-height:1.55;
      color:rgba(248,239,221,0.78);
    }

    .profile-title span{
      color:#8ddcff;
      font-weight:800;
    }

    .stat-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      margin-top:10px;
    }

    .stat-box{
      padding:12px 12px 10px;
      border-radius:12px;
      background:rgba(255,245,220,0.06);
      border:1px solid rgba(255,255,255,0.08);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.04),
        0 4px 10px rgba(0,0,0,0.12);
    }

    .stat-label{
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:0.8px;
      color:rgba(247,238,220,0.58);
      margin-bottom:6px;
    }

    .stat-value{
      font-family:"Cinzel", serif;
      font-size:18px;
      color:#f7ebcb;
    }

    .objective-list{
      padding-left:18px;
      font-size:13px;
      line-height:1.85;
      color:rgba(247,238,220,0.86);
    }

    .objective-list li{
      margin-bottom:4px;
    }

    .objective-note{
      margin-top:14px;
      font-size:12px;
      line-height:1.65;
      color:rgba(247,238,220,0.64);
    }

    .right-menu{
      position:absolute;
      right:40px;
      top:50%;
      transform:translateY(-50%);
      width:350px;
      padding:22px 18px 18px;
      animation:fadeRight 0.6s ease;
      transition:opacity 0.28s ease, transform 0.28s ease;
    }

    .menu-top{
      margin-bottom:22px;
      padding-bottom:18px;
      border-bottom:1px solid rgba(255,255,255,0.08);
    }

    .player-name{
      font-size:22px;
      font-weight:800;
      line-height:1.2;
      margin-bottom:10px;
    }

    .player-title{
      font-size:12px;
      line-height:1.55;
      color:rgba(247,238,220,0.72);
      margin-bottom:10px;
      text-transform:uppercase;
      letter-spacing:0.4px;
    }

    .player-title span{
      color:#8ddcff;
      font-weight:800;
      text-transform:none;
      letter-spacing:0;
      overflow-wrap:anywhere;
    }

    .player-level{
      font-family:"Cinzel", serif;
      font-size:18px;
      color:#f7ebcb;
      margin-bottom:12px;
    }

    .progress-wrapper{
      margin-bottom:10px;
    }

    .progress-bar{
      width:100%;
      height:14px;
      border-radius:999px;
      overflow:hidden;
      background:rgba(255,245,220,0.06);
      border:1px solid rgba(255,255,255,0.06);
      box-shadow:inset 0 2px 6px rgba(0,0,0,0.18);
    }

    .progress{
      height:100%;
      border-radius:999px;
      background:
        repeating-linear-gradient(
          45deg,
          rgba(255,255,255,0.18) 0px,
          rgba(255,255,255,0.18) 4px,
          rgba(255,255,255,0.02) 4px,
          rgba(255,255,255,0.02) 8px
        ),
        linear-gradient(90deg, #30c8f7, #49a7ff);
      box-shadow:0 0 12px rgba(73,167,255,0.22);
      transition:width 0.4s ease;
    }

    .score-row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      font-size:12px;
      color:rgba(247,238,220,0.74);
    }

    .gift-area{
      position:relative;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .gift-icon{
      font-size:22px;
      cursor:pointer;
      user-select:none;
      animation:giftPulse 2s infinite;
    }

    @keyframes giftPulse{
      0%,100%{transform:scale(1);}
      50%{transform:scale(1.12);}
    }

    .progress-tooltip{
      position:absolute;
      right:0;
      bottom:34px;
      width:220px;
      padding:10px 12px;
      border-radius:14px;
      background:rgba(38,28,18,0.95);
      border:1px solid rgba(255,255,255,0.08);
      color:#f6ead1;
      font-size:12px;
      line-height:1.6;
      box-shadow:0 12px 22px rgba(0,0,0,0.22);
      opacity:0;
      transform:translateY(6px);
      pointer-events:none;
      transition:0.2s ease;
      text-align:left;
      z-index:30;
    }

    .gift-area:hover .progress-tooltip{
      opacity:1;
      transform:translateY(0);
    }

    .menu-title{
      text-align:center;
      font-size:28px;
      margin-bottom:16px;
      letter-spacing:0.6px;
    }

    .menu-title::after{
      margin-left:auto;
      margin-right:auto;
    }

    /* ==== UPDATED BUTTON STYLE ==== */

    .menu-link{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      width:100%;
      text-decoration:none;
      text-align:center;
      font-family:"Cinzel", serif;
      font-size:16px;
      font-weight:700;
      padding:14px 18px;
      margin-bottom:12px;
      border-radius:14px;
      color:#f7e7c6;
      background:
        radial-gradient(circle at 18% 50%, rgba(0,255,180,0.08), transparent 42%),
        linear-gradient(180deg, rgba(122,90,43,0.96), rgba(74,52,26,0.98));
      border:1px solid rgba(215,180,110,0.25);
      box-shadow:
        0 10px 20px rgba(0,0,0,0.35),
        inset 0 1px 0 rgba(255,240,200,0.25),
        inset 0 -2px 6px rgba(0,0,0,0.4);
      position:relative;
      overflow:hidden;
      transition:all 0.2s ease;
      letter-spacing:0.2px;
      cursor:pointer;
    }

    .menu-link::before{
      content:"";
      position:absolute;
      left:0;
      top:0;
      bottom:0;
      width:4px;
      background:linear-gradient(180deg, rgba(0,255,180,0), rgba(0,255,180,0.85), rgba(0,255,180,0));
      opacity:0.75;
    }

    .menu-link::after{
      content:"";
      position:absolute;
      right:12px;
      top:50%;
      transform:translateY(-50%);
      width:12px;
      height:12px;
      border-radius:50%;
      background:
        radial-gradient(circle at 30% 30%, #6fffce, #0f7a5c);
      box-shadow:
        0 0 8px rgba(0,255,180,0.6),
        0 0 14px rgba(0,255,180,0.4);
    }

    .menu-link:hover{
      transform:translateY(-3px) scale(1.02);
      background:
        radial-gradient(circle at 24% 50%, rgba(0,255,180,0.18), transparent 46%),
        linear-gradient(180deg, rgba(156,116,54,0.98), rgba(90,63,31,0.99));
      box-shadow:
        0 14px 30px rgba(0,0,0,0.45),
        0 0 18px rgba(255,220,140,0.25),
        inset 0 1px 0 rgba(255,240,200,0.35);
      border-color:rgba(255,220,150,0.35);
    }

    .menu-link:active{
      transform:scale(0.96);
    }

    .menu-link.logout{
      background:
        radial-gradient(circle at 18% 50%, rgba(255,80,80,0.12), transparent 42%),
        linear-gradient(180deg, rgba(107,45,45,0.96), rgba(58,24,24,0.98));
      border-color:rgba(255,120,120,0.30);
    }

    .menu-link.logout::before{
      background:linear-gradient(180deg, rgba(255,90,90,0), rgba(255,90,90,0.85), rgba(255,90,90,0));
    }

    .menu-link.logout::after{
      background:
        radial-gradient(circle at 30% 30%, #ff9a9a, #7a1f1f);
      box-shadow:
        0 0 8px rgba(255,80,80,0.6),
        0 0 14px rgba(255,80,80,0.4);
    }

    .menu-icon{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:20px;
      min-width:20px;
      font-size:15px;
      line-height:1;
      filter:drop-shadow(0 1px 2px rgba(0,0,0,0.28));
    }

    .menu-text{
      position:relative;
      z-index:2;
    }

    .music-btn{
      position:absolute;
      top:18px;
      right:18px;
      z-index:45;
      width:52px;
      height:52px;
      border-radius:50%;
      border:1px solid rgba(225,190,120,0.18);
      background:
        linear-gradient(180deg, rgba(120,83,42,0.94), rgba(85,58,30,0.98));
      color:#f6e8ca;
      font-size:20px;
      cursor:pointer;
      box-shadow:
        0 10px 20px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,245,220,0.08);
      transition:all 0.18s ease;
    }

    .music-btn:hover{
      transform:translateY(-2px) scale(1.03);
    }

    .music-btn.is-off{
      opacity:0.72;
    }

    .wings-emblem{
      position:absolute;
      right:22px;
      bottom:18px;
      z-index:20;
      width:120px;
      opacity:0.88;
      pointer-events:none;
      filter:
        drop-shadow(0 8px 14px rgba(0,0,0,0.28))
        drop-shadow(0 0 6px rgba(255,220,120,0.10));
    }

    .wings-emblem img{
      width:100%;
      height:auto;
      display:block;
      object-fit:contain;
    }

    @keyframes fadeLeft{
      from{
        opacity:0;
        transform:translateY(-50%) translateX(-12px) scale(0.97);
      }
      to{
        opacity:1;
        transform:translateY(-50%) translateX(0) scale(1);
      }
    }

    @keyframes fadeRight{
      from{
        opacity:0;
        transform:translateY(-50%) translateX(14px) scale(0.97);
      }
      to{
        opacity:1;
        transform:translateY(-50%) translateX(0) scale(1);
      }
    }

    @media (max-width: 1100px){
      .left-side{
        width:255px;
        left:20px;
      }

      .right-menu{
        width:320px;
        right:24px;
      }
    }

    @media (max-width: 900px){
      .left-side{
        display:none;
      }

      .right-menu{
        right:26px;
        width:340px;
      }

      .wings-emblem{
        width:96px;
      }
    }

    @media (max-width: 650px){
      .right-menu{
        left:50%;
        right:auto;
        top:52%;
        transform:translate(-50%, -50%);
        width:min(92vw, 360px);
      }

      .notification-stack{
        width:92%;
      }

      .notify{
        width:100%;
        min-width:unset;
      }

      .wings-emblem{
        width:82px;
        right:12px;
        bottom:12px;
      }

      .music-btn{
        top:14px;
        right:14px;
      }
    }
  </style>
</head>
<body>

<%
  const safeProgress = isNaN(progress) ? 0 : progress;
  const progressPercent = Math.max(0, Math.min(100, safeProgress * 100)).toFixed(2);

  const currentCharacter = user.selectedCharacter || "Eren Yeager";
  const avatarSrc = user.avatar || "";
%>

<%- include("partials/music") %>

<div class="menu-container">

  <div class="notification-stack">
    <% if(titleUnlocked){ %>
      <div class="notify unlock">🎉 <%= titleUnlocked %></div>
    <% } %>

    <% if(levelUp){ %>
      <div class="notify levelup">⭐ <%= levelUp %></div>
    <% } %>
  </div>

  <div class="left-side">
    <div class="aot-panel left-card profile-card">
      <div class="panel-top-strip"></div>
      <div class="metal-frame"></div>
      <div class="panel-bolts"><span></span><span></span><span></span><span></span></div>
      <div class="panel-content">
        <div class="section-title">Scout Profile</div>

        <div class="profile-row">
          <div class="avatar-box">
            <% if (avatarSrc) { %>
              <img src="<%= avatarSrc %>" alt="Avatar">
            <% } else { %>
              <div class="avatar-placeholder">🛡️</div>
            <% } %>
          </div>

          <div class="profile-meta">
            <div class="profile-name"><%= user.username %></div>
            <div class="profile-title">
              Title: <span><%= user.title %></span><br>
              Character: <strong><%= currentCharacter %></strong>
            </div>
          </div>
        </div>

        <div class="stat-grid">
          <div class="stat-box">
            <div class="stat-label">Level</div>
            <div class="stat-value"><%= level %></div>
          </div>

          <div class="stat-box">
            <div class="stat-label">Score</div>
            <div class="stat-value"><%= user.totalScore %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="aot-panel left-card objective-card">
      <div class="panel-top-strip"></div>
      <div class="metal-frame"></div>
      <div class="panel-bolts"><span></span><span></span><span></span><span></span></div>
      <div class="panel-content">
        <div class="section-title">Current Objective</div>

        <ul class="objective-list">
          <li>Continue the expedition</li>
          <li>Defeat titans for score</li>
          <li>Collect supplies and boosts</li>
          <li>Unlock the next reward</li>
        </ul>

        <div class="objective-note">
          The fate of humanity depends on your progress beyond the walls.
        </div>
      </div>
    </div>
  </div>

  <div class="aot-panel right-menu">
    <div class="panel-top-strip"></div>
    <div class="metal-frame"></div>
    <div class="panel-bolts"><span></span><span></span><span></span><span></span></div>
    <div class="panel-rivets">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="panel-content">
      <div class="menu-top">
        <div class="player-name">Welcome, <%= user.username %></div>

        <div class="player-title">
          Current Title: <span><%= user.title %></span>
        </div>

        <div class="player-level">
          Level <%= level %>
        </div>

        <div class="progress-wrapper">
          <div class="progress-bar">
            <div class="progress" style="width:<%= progressPercent %>%;"></div>
          </div>
        </div>

        <div class="score-row">
          <span><%= user.totalScore %> / <%= nextLevel %> score</span>

          <div class="gift-area">
            <div class="gift-icon">🎁</div>

            <div class="progress-tooltip">
              <strong>Next Level Rewards:</strong><br>
              <% nextLevelRewards.forEach(r => { %>
                • <%= r %><br>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <h2 class="menu-title">Main Menu</h2>

      <a class="menu-link" href="/map">
        <span class="menu-icon">⚔</span>
        <span class="menu-text">Start Game</span>
      </a>

      <a class="menu-link" href="/profile">
        <span class="menu-icon">👤</span>
        <span class="menu-text">My Profile</span>
      </a>

      <a class="menu-link" href="/account">
        <span class="menu-icon">🛠</span>
        <span class="menu-text">My Account</span>
      </a>

      <a class="menu-link" href="/leaderboard">
        <span class="menu-icon">🏆</span>
        <span class="menu-text">Leaderboard</span>
      </a>

      <a class="menu-link" href="/market">
        <span class="menu-icon">💰</span>
        <span class="menu-text">Market</span>
      </a>

      <a class="menu-link" href="/how-to-play">
        <span class="menu-icon">📖</span>
        <span class="menu-text">How to Play</span>
      </a>

      <a class="menu-link" href="/titles">
        <span class="menu-icon">✦</span>
        <span class="menu-text">Titles</span>
      </a>

      <a class="menu-link logout" href="/logout">
        <span class="menu-icon">⎋</span>
        <span class="menu-text">Logout</span>
      </a>
    </div>
  </div>

  <button class="music-btn" onclick="toggleMusic()">♫</button>

  <div class="wings-emblem">
    <img src="/images/book-cover.png" alt="Wings of Freedom">
  </div>

  <div class="screen-fade"></div>

  <audio id="menuHoverSound" preload="auto">
    <source src="/sounds/menu-hover.wav" type="audio/wav">
  </audio>

  <audio id="menuClickSound" preload="auto">
    <source src="/sounds/menu-click.wav" type="audio/wav">
  </audio>

  <audio id="menuMusic" preload="auto" loop>
    <source src="/sounds/menu-music.mp3" type="audio/mpeg">
  </audio>

</div>

<script>
  const hoverSound = document.getElementById("menuHoverSound");
  const clickSound = document.getElementById("menuClickSound");
  const menuMusic = document.getElementById("menuMusic");
  const musicToggle = document.getElementById("musicToggle");
  const menuLinks = document.querySelectorAll(".menu-link");
  let audioUnlocked = false;
  let leaving = false;
  let musicStarted = false;

  function safePlay(audio, volume = 0.35) {
    if (!audio) return;
    try {
      audio.pause();
      audio.currentTime = 0;
      audio.volume = volume;
      const p = audio.play();
      if (p && typeof p.catch === "function") p.catch(() => {});
    } catch (_) {}
  }


function toggleMusic(){
  const music = document.getElementById("bgMusic");

  if(music.paused){
    music.play();
    localStorage.setItem("bgMusicPlaying","true");
  }else{
    music.pause();
    localStorage.setItem("bgMusicPlaying","false");
  }
}


  function startMusic() {
    if (!menuMusic || musicStarted) return;
    menuMusic.volume = 0.28;
    const p = menuMusic.play();
    if (p && typeof p.then === "function") {
      p.then(() => {
        musicStarted = true;
        musicToggle.classList.remove("is-off");
      }).catch(() => {});
    }
  }

  function unlockAudio() {
    if (!audioUnlocked) {
      audioUnlocked = true;
      [hoverSound, clickSound].forEach(audio => {
        if (!audio) return;
        audio.volume = 0;
        const p = audio.play();
        if (p && typeof p.then === "function") {
          p.then(() => {
            audio.pause();
            audio.currentTime = 0;
            audio.volume = 1;
          }).catch(() => {});
        }
      });
    }
    startMusic();
  }

  menuLinks.forEach(link => {
    link.addEventListener("mouseenter", () => {
      if (!audioUnlocked || leaving) return;
      safePlay(hoverSound, 0.18);
    });

    link.addEventListener("click", (e) => {
      if (leaving) {
        e.preventDefault();
        return;
      }

      const href = link.getAttribute("href");
      if (!href || href.startsWith("#")) return;

      e.preventDefault();
      leaving = true;
      document.body.classList.add("page-leaving");
      if (audioUnlocked) {
        safePlay(clickSound, 0.28);
      }

      setTimeout(() => {
        window.location.href = href;
      }, 280);
    });
  });


  
  musicToggle.addEventListener("click", () => {
    unlockAudio();

    if (!menuMusic) return;

    if (menuMusic.paused) {
      menuMusic.volume = 0.28;
      const p = menuMusic.play();
      if (p && typeof p.catch === "function") p.catch(() => {});
      musicToggle.classList.remove("is-off");
    } else {
      menuMusic.pause();
      musicToggle.classList.add("is-off");
    }
  });

  


  window.addEventListener("pointerdown", unlockAudio, { once: true });
  window.addEventListener("keydown", unlockAudio, { once: true });
</script>

</body>
</html>