<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title>Main Menu</title>
  <style>
    body{
      margin:0;
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background:#111;
      color:white;
      font-family:Arial, Helvetica, sans-serif;
      background-image:url("/images/image10.png");
      background-size:cover;
      background-position:center;
    }

    .box{
      width:450px;
      background:rgba(0,0,0,0.65);
      padding:40px;
      border-radius:12px;
      text-align:center;
    }

    h1{
      margin-bottom:12px;
    }

    p{
      margin-bottom:25px;
    }

    a{
      display:block;
      margin:14px 0;
      color:white;
      text-decoration:none;
      font-size:18px;
      font-weight:bold;
      padding:12px;
      border-radius:8px;
      background:rgba(255,255,255,0.12);
    }

    a:hover{
      background:rgba(255,255,255,0.2);
    }
  </style>
</head>
<body>
  <div class="box">
    <h1>Attack on Titan Game</h1>
    <p>Welcome, <%= currentUser ? currentUser.username : "Player" %></p>

    <a href="/game">Start Game</a>
    <a href="/account">My Account</a>
    <a href="/how-to-play">How to Play</a>
    <a href="/market">Market</a>
    <a href="/leaderboard">Leaderboard</a>
    <a href="/logout">Logout</a>
  </div>
</body>
</html>