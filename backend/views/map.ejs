<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Level Map</title>

  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      width:100vw;
      height:100vh;
      overflow:hidden;
      background:#111;
      font-family:"Inter", sans-serif;
      color:#f3ede2;
    }

    .map-container{
      position:relative;
      width:100%;
      height:100%;
      background:url("/images/map-menu.png") center/cover no-repeat;
      isolation:isolate;
    }

    .map-container::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at center,
          rgba(0,0,0,0) 22%,
          rgba(0,0,0,0.22) 68%,
          rgba(0,0,0,0.44) 100%);
      z-index:1;
      pointer-events:none;
    }

    .map-container::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(rgba(20,16,12,0.10), rgba(20,16,12,0.10)),
        linear-gradient(rgba(90,70,45,0.03), rgba(90,70,45,0.03));
      z-index:1;
      pointer-events:none;
      animation:mapBreath 8s ease-in-out infinite;
    }

    @keyframes mapBreath{
      0%,100%{opacity:0.08;}
      50%{opacity:0.14;}
    }

    .aot-panel{
      position:absolute;
      z-index:10;
      overflow:hidden;
      border-radius:18px;
      background:
        radial-gradient(circle at 50% 20%, rgba(255,246,220,0.12), transparent 38%),
        linear-gradient(180deg, rgba(70,50,26,0.86), rgba(43,31,18,0.90));
      border:1px solid rgba(215,182,112,0.20);
      box-shadow:
        0 18px 34px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,245,220,0.12),
        inset 0 -1px 0 rgba(0,0,0,0.22);
      backdrop-filter:blur(8px);
      -webkit-backdrop-filter:blur(8px);
    }

    .aot-panel::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.05), transparent 18%, transparent 82%, rgba(0,0,0,0.14)),
        repeating-linear-gradient(
          135deg,
          rgba(255,255,255,0.015) 0px,
          rgba(255,255,255,0.015) 2px,
          transparent 2px,
          transparent 16px
        );
      pointer-events:none;
    }

    .aot-panel::after{
      content:"";
      position:absolute;
      inset:8px;
      border:1px solid rgba(232,205,146,0.10);
      border-radius:12px;
      pointer-events:none;
      box-shadow:inset 0 0 18px rgba(0,0,0,0.10);
    }

    .panel-top-strip{
      position:absolute;
      top:0;
      left:20px;
      right:20px;
      height:3px;
      border-radius:999px;
      background:linear-gradient(90deg, rgba(224,190,120,0.0), rgba(224,190,120,0.88), rgba(224,190,120,0.0));
      z-index:3;
      pointer-events:none;
    }

    .panel-bolts{
      position:absolute;
      inset:0;
      pointer-events:none;
      z-index:3;
    }

    .panel-bolts span{
      position:absolute;
      width:10px;
      height:10px;
      border-radius:50%;
      background:
        radial-gradient(circle at 35% 35%, #dcc089, #76562f 72%);
      box-shadow:
        inset 0 1px 1px rgba(255,255,255,0.22),
        0 1px 3px rgba(0,0,0,0.35);
      opacity:0.78;
    }

    .panel-bolts span:nth-child(1){ top:12px; left:12px; }
    .panel-bolts span:nth-child(2){ top:12px; right:12px; }
    .panel-bolts span:nth-child(3){ bottom:12px; left:12px; }
    .panel-bolts span:nth-child(4){ bottom:12px; right:12px; }

    .metal-frame{
      position:absolute;
      inset:0;
      border-radius:18px;
      pointer-events:none;
      z-index:3;
      background:
        linear-gradient(90deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) top / 100% 1px no-repeat,
        linear-gradient(90deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) bottom / 100% 1px no-repeat,
        linear-gradient(180deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) left / 1px 100% no-repeat,
        linear-gradient(180deg, rgba(226,194,122,0.28), rgba(226,194,122,0.06)) right / 1px 100% no-repeat;
    }

    .panel-content{
      position:relative;
      z-index:4;
    }

    .music-btn{
      position:absolute;
      top:18px;
      right:18px;
      z-index:45;
      width:52px;
      height:52px;
      border-radius:50%;
      border:1px solid rgba(225,190,120,0.18);
      background:
        linear-gradient(180deg, rgba(120,83,42,0.94), rgba(85,58,30,0.98));
      color:#f6e8ca;
      font-size:20px;
      cursor:pointer;
      box-shadow:
        0 10px 20px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,245,220,0.08);
      transition:all 0.18s ease;
    }

    .music-btn:hover{
      transform:translateY(-2px) scale(1.03);
    }

    .left-side{
      position:absolute;
      left:28px;
      top:50%;
      transform:translateY(-50%);
      width:285px;
      z-index:12;
      display:flex;
      flex-direction:column;
      gap:16px;
    }

    .left-card{
      position:relative;
      padding:18px;
    }

    .section-title,
    .map-title{
      font-family:"Cinzel", serif;
      color:#f4e4bc;
      text-shadow:0 2px 8px rgba(0,0,0,0.28);
    }

    .section-title{
      font-size:20px;
      margin-bottom:14px;
      letter-spacing:0.4px;
    }

    .section-title::after,
    .map-title::after{
      content:"";
      display:block;
      width:52px;
      height:1px;
      background:rgba(227,197,128,0.50);
      margin-top:8px;
    }

    .map-title{
      text-align:center;
      font-size:26px;
      margin-bottom:14px;
      letter-spacing:0.5px;
    }

    .map-title::after{
      margin-left:auto;
      margin-right:auto;
    }

    .welcome{
      font-size:17px;
      font-weight:800;
      margin-bottom:10px;
      color:#f5ecd6;
    }

    .map-level{
      font-family:"Cinzel", serif;
      font-size:18px;
      color:#f7ebcb;
      margin-bottom:12px;
    }

    .progress-bar{
      width:100%;
      height:14px;
      border-radius:999px;
      overflow:hidden;
      background:rgba(255,245,220,0.06);
      border:1px solid rgba(255,255,255,0.06);
      box-shadow:inset 0 2px 6px rgba(0,0,0,0.18);
      margin-bottom:10px;
    }

    .progress{
      height:100%;
      border-radius:999px;
      background:
        repeating-linear-gradient(
          45deg,
          rgba(255,255,255,0.18) 0px,
          rgba(255,255,255,0.18) 4px,
          rgba(255,255,255,0.02) 4px,
          rgba(255,255,255,0.02) 8px
        ),
        linear-gradient(90deg, #30c8f7, #49a7ff);
      box-shadow:0 0 12px rgba(73,167,255,0.22);
      transition:width 0.4s ease;
    }

    .score-text,
    .sub-info{
      font-size:13px;
      color:rgba(247,238,220,0.78);
      line-height:1.6;
    }

    .title-label{
      font-size:12px;
      line-height:1.55;
      color:rgba(247,238,220,0.72);
      margin-bottom:6px;
      text-transform:uppercase;
      letter-spacing:0.4px;
    }

    .title-name{
      font-family:"Cinzel", serif;
      font-size:18px;
      color:#8ddcff;
      line-height:1.35;
      overflow-wrap:anywhere;
    }

    .right-side{
      position:absolute;
      right:28px;
      top:26px;
      width:260px;
      z-index:12;
      display:flex;
      flex-direction:column;
      gap:14px;
    }

    .right-card{
      position:relative;
      padding:18px;
    }

    .map-actions{
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .action-btn{
      display:flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      width:100%;
      text-decoration:none;
      text-align:center;
      font-family:"Cinzel", serif;
      font-size:14px;
      font-weight:700;
      padding:12px 14px;
      border-radius:14px;
      color:#f7e7c6;
      background:
        radial-gradient(circle at 18% 50%, rgba(0,255,180,0.08), transparent 42%),
        linear-gradient(180deg, rgba(122,90,43,0.96), rgba(74,52,26,0.98));
      border:1px solid rgba(215,180,110,0.25);
      box-shadow:
        0 10px 20px rgba(0,0,0,0.35),
        inset 0 1px 0 rgba(255,240,200,0.25),
        inset 0 -2px 6px rgba(0,0,0,0.4);
      position:relative;
      overflow:hidden;
      transition:all 0.2s ease;
      letter-spacing:0.2px;
      cursor:pointer;
    }

    .action-btn::before{
      content:"";
      position:absolute;
      left:0;
      top:0;
      bottom:0;
      width:4px;
      background:linear-gradient(180deg, rgba(0,255,180,0), rgba(0,255,180,0.85), rgba(0,255,180,0));
      opacity:0.75;
    }

    .action-btn:hover{
      transform:translateY(-3px) scale(1.02);
      background:
        radial-gradient(circle at 24% 50%, rgba(0,255,180,0.18), transparent 46%),
        linear-gradient(180deg, rgba(156,116,54,0.98), rgba(90,63,31,0.99));
    }

    .action-btn.secondary::before{
      background:linear-gradient(180deg, rgba(255,220,140,0), rgba(255,220,140,0.85), rgba(255,220,140,0));
    }

    .hotspot{
      position:absolute;
      display:block;
      width:112px;
      height:58px;
      text-decoration:none;
      border-radius:14px;
      transition:0.22s ease;
      overflow:visible;
      z-index:8;
    }

    .hotspot.open{
      background:
        radial-gradient(circle at 18% 50%, rgba(0,255,180,0.06), transparent 42%),
        linear-gradient(180deg, rgba(122,90,43,0.84), rgba(74,52,26,0.92));
      border:1px solid rgba(215,180,110,0.22);
      box-shadow:
        0 8px 16px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,240,200,0.16);
    }

    .hotspot.open:hover{
      transform:translateY(-2px) scale(1.03);
      background:
        radial-gradient(circle at 24% 50%, rgba(0,255,180,0.14), transparent 46%),
        linear-gradient(180deg, rgba(156,116,54,0.92), rgba(90,63,31,0.96));
      box-shadow:
        0 12px 24px rgba(0,0,0,0.36),
        0 0 18px rgba(255,220,140,0.16);
    }

    .hotspot.locked{
      background:rgba(16,12,9,0.62);
      border:1px solid rgba(255,255,255,0.08);
      box-shadow:0 8px 14px rgba(0,0,0,0.22);
      cursor:not-allowed;
      opacity:0.82;
    }

    .hotspot.current{
      box-shadow:
        0 0 0 2px rgba(73,167,255,0.85),
        0 0 18px rgba(73,167,255,0.35),
        0 10px 20px rgba(0,0,0,0.35);
    }

    .label{
      position:absolute;
      left:50%;
      top:50%;
      transform:translate(-50%, -50%);
      color:#f7e7c6;
      font-family:"Cinzel", serif;
      font-size:14px;
      font-weight:700;
      text-shadow:0 2px 8px rgba(0,0,0,0.85);
      white-space:nowrap;
      text-align:center;
      pointer-events:none;
      line-height:1.2;
      letter-spacing:0.2px;
    }

    .lock-icon{
      position:absolute;
      top:6px;
      right:8px;
      font-size:16px;
      pointer-events:none;
    }

    .tooltip{
      position:absolute;
      left:50%;
      bottom:70px;
      transform:translateX(-50%);
      width:220px;
      background:rgba(31,23,17,0.94);
      color:#f6ead1;
      padding:12px;
      border-radius:12px;
      font-size:12px;
      line-height:1.55;
      opacity:0;
      transition:0.22s ease;
      pointer-events:none;
      box-shadow:0 12px 24px rgba(0,0,0,0.32);
      border:1px solid rgba(255,255,255,0.08);
    }

    .tooltip strong{
      display:block;
      margin-bottom:6px;
      color:#8fefff;
      font-size:13px;
    }

    .hotspot:hover .tooltip{
      opacity:1;
      bottom:76px;
    }

    .wings-emblem{
      position:absolute;
      right:22px;
      bottom:18px;
      z-index:20;
      width:120px;
      opacity:0.88;
      pointer-events:none;
      filter:
        drop-shadow(0 8px 14px rgba(0,0,0,0.28))
        drop-shadow(0 0 6px rgba(255,220,120,0.10));
    }

    .wings-emblem img{
      width:100%;
      height:auto;
      display:block;
      object-fit:contain;
    }

    @media (max-width: 1100px){
      .left-side{ width:260px; left:20px; }
      .right-side{ width:238px; right:20px; }
      .hotspot{ width:102px; height:54px; }
    }

    @media (max-width: 900px){
      .left-side{ display:none; }
      .right-side{ right:20px; width:240px; }
    }

    @media (max-width: 700px){
      .right-side{
        left:50%;
        right:auto;
        top:18px;
        transform:translateX(-50%);
        width:min(92vw, 320px);
      }
      .hotspot{ width:94px; height:50px; }
      .label{ font-size:12px; }
      .wings-emblem{ display:none; }
    }

    .sector-modal{
  position:fixed;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  background:transparent;
  z-index:999;
  opacity:1;
}

.sector-modal.hidden{
  display:none;
}

.sector-box{
  position:relative;
  width:min(880px, 92vw);
  padding:22px 24px 24px 24px;
  border-radius:22px;
  transform:scale(1);
  animation:sectorModalIn .18s ease;
}

@keyframes sectorModalIn{
  from{
    opacity:0;
    transform:scale(.96) translateY(10px);
  }
  to{
    opacity:1;
    transform:scale(1) translateY(0);
  }
}

.sector-close{
  position:absolute;
  top:14px;
  right:14px;
  width:40px;
  height:40px;
  border:none;
  border-radius:50%;
  cursor:pointer;
  font-size:24px;
  line-height:1;
  display:flex;
  align-items:center;
  justify-content:center;
  color:#f6e8ca;
  background:
    radial-gradient(circle at 35% 30%, rgba(255,255,255,0.18), transparent 35%),
    linear-gradient(180deg, rgba(130,90,44,0.98), rgba(83,57,29,0.98));
  box-shadow:
    0 8px 18px rgba(0,0,0,0.24),
    inset 0 1px 0 rgba(255,245,220,0.10);
  z-index:10;
  transition:.18s ease;
}

.sector-close:hover{
  transform:scale(1.06);
}

.sector-header{
  text-align:left;
  margin-bottom:18px;
  padding-right:56px;
}

.sector-header-top{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  gap:14px;
}

.sector-header h2{
  font-family:"Cinzel", serif;
  font-size:30px;
  color:#f4e4bc;
  margin-bottom:6px;
  letter-spacing:.4px;
}

.sector-header p{
  font-size:14px;
  color:rgba(247,238,220,0.82);
}

.sector-badge{
  padding:8px 12px;
  border-radius:999px;
  font-size:11px;
  font-weight:700;
  letter-spacing:.5px;
  text-transform:uppercase;
  color:#f6e6bf;
  background:
    linear-gradient(180deg, rgba(117,83,40,0.95), rgba(72,50,25,0.98));
  border:1px solid rgba(215,182,112,0.22);
  white-space:nowrap;
}

.sector-divider{
  width:100%;
  height:1px;
  margin:14px 0 12px 0;
  background:linear-gradient(
    90deg,
    rgba(223,190,124,0),
    rgba(223,190,124,0.7),
    rgba(223,190,124,0)
  );
}

.sector-progress-line{
  font-size:12px;
  color:rgba(247,238,220,0.78);
}

.sector-grid-wrap{
  width:100%;
  border-radius:18px;
  padding:18px;
  background:
    radial-gradient(circle at 50% 20%, rgba(255,246,220,0.06), transparent 40%),
    linear-gradient(180deg, rgba(97,70,34,0.48), rgba(55,39,20,0.58));
  border:1px solid rgba(215,182,112,0.14);
  box-shadow:
    inset 0 1px 0 rgba(255,245,220,0.08),
    inset 0 -1px 0 rgba(0,0,0,0.18);
}

.sector-grid{
  display:grid;
  grid-template-columns:repeat(5, 122px);
  justify-content:center;
  gap:14px;
}

.sector-card{
  width:122px;
  height:122px;
  border-radius:16px;
  padding:10px 8px;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  text-decoration:none;
  color:#f7e7c6;
  background:
    radial-gradient(circle at 18% 50%, rgba(0,255,180,0.04), transparent 42%),
    linear-gradient(180deg, rgba(122,90,43,0.92), rgba(74,52,26,0.97));
  border:1px solid rgba(215,180,110,0.24);
  box-shadow:
    0 8px 16px rgba(0,0,0,0.22),
    inset 0 1px 0 rgba(255,240,200,0.10);
  transition:.18s ease;
  position:relative;
  overflow:hidden;
}

.sector-card::after{
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.02), transparent 35%, transparent 65%, rgba(255,255,255,0.02));
  pointer-events:none;
}

.sector-card:hover{
  transform:translateY(-2px) scale(1.02);
  background:
    radial-gradient(circle at 24% 50%, rgba(0,255,180,0.08), transparent 46%),
    linear-gradient(180deg, rgba(156,116,54,0.95), rgba(90,63,31,0.98));
}

.sector-card.locked{
  opacity:.42;
  pointer-events:none;
  filter:grayscale(.22);
  background:rgba(16,12,9,0.76);
}

.sector-card.current{
  box-shadow:
    0 0 0 2px rgba(73,167,255,0.88),
    0 0 18px rgba(73,167,255,0.32),
    0 10px 18px rgba(0,0,0,0.30);
}

.sector-card.completed{
  box-shadow:
    0 0 0 1px rgba(80,210,140,0.65),
    0 0 14px rgba(80,210,140,0.18),
    0 10px 18px rgba(0,0,0,0.22);
}

.sector-icon{
  font-size:14px;
  margin-bottom:6px;
  opacity:.95;
}

.sector-num{
  font-family:"Cinzel", serif;
  font-size:14px;
  font-weight:800;
  color:#f4e4bc;
  margin-bottom:4px;
}

.sector-text{
  font-size:9px;
  line-height:1.3;
  color:rgba(247,238,220,0.9);
  min-height:24px;
}

.sector-state{
  margin-top:7px;
  font-size:8px;
  opacity:.8;
  text-transform:uppercase;
  letter-spacing:0.4px;
}

.sector-corner-badge{
  position:absolute;
  top:7px;
  right:7px;
  font-size:10px;
  opacity:.9;
}

@media (max-width: 900px){
  .sector-box{
    width:min(760px, 94vw);
  }

  .sector-grid{
    grid-template-columns:repeat(4, 110px);
  }

  .sector-card{
    width:110px;
    height:110px;
  }
}

@media (max-width: 700px){
  .sector-box{
    width:min(95vw, 95vw);
    padding:18px 14px;
  }

  .sector-grid-wrap{
    padding:14px;
  }

  .sector-grid{
    grid-template-columns:repeat(3, 95px);
    gap:10px;
  }

  .sector-card{
    width:95px;
    height:95px;
  }

  .sector-header h2{
    font-size:24px;
  }

  .sector-header p{
    font-size:12px;
  }

  .sector-header-top{
    flex-direction:column;
    align-items:flex-start;
  }
}
  
  </style>
</head>
<body>

<button class="music-btn" onclick="toggleMusic()">♫</button>
<%- include("partials/music") %>

<%
  const safeProgress = isNaN(progress) ? 0 : progress;
  const progressPercent = Math.max(0, Math.min(100, safeProgress * 100)).toFixed(2);

  const s1 = stageData[0];
  const s2 = stageData[1];
  const s3 = stageData[2];
  const s4 = stageData[3];
  const s5 = stageData[4];

  const currentTitle =
    user.title ||
    (user.unlockedTitles && user.unlockedTitles.length ? user.unlockedTitles[user.unlockedTitles.length - 1] : "New Recruit");

  const continueLevel = user.currentLevel || 1;
  const continueSector = user.currentSector || 1;
%>

<div class="map-container">

  <div class="left-side">
    <div class="aot-panel left-card">
      <div class="panel-top-strip"></div>
      <div class="metal-frame"></div>
      <div class="panel-bolts"><span></span><span></span><span></span><span></span></div>
      <div class="panel-content">
        <div class="section-title">Scout Progress</div>
        <div class="welcome">Welcome, <%= user.username %></div>
        <div class="map-level">Current Level: <%= user.level || 1 %></div>

        <div class="progress-bar">
          <div class="progress" style="width:<%= progressPercent %>%;"></div>
        </div>

