<script>
  function toggleMusic(){
    const music = document.getElementById("bgMusic");
    if(!music) return;

    if(music.paused){
      music.play();
      localStorage.setItem("bgMusicPlaying","true");
    }else{
      music.pause();
      localStorage.setItem("bgMusicPlaying","false");
    }
  }

  function openSectorModal(level) {
    const modal = document.getElementById("sectorModal");
    const grid = document.getElementById("sectorGrid");
    const title = document.getElementById("sectorModalTitle");
    const subtitle = document.getElementById("sectorModalSubtitle");

    const levelData = gameLevels[level];
    if (!levelData) return;

    title.textContent = levelData.name || `Battle ${level}`;
    grid.innerHTML = "";

    for (let i = 1; i <= 10; i++) {
      const sectorData = levelData.sectors[i];

      const isOpen =
        isAdmin ||
        level < currentLevel ||
        (level === currentLevel && i <= currentSector) ||
        (level === 1 && i === 1);

      const card = document.createElement(isOpen ? "a" : "div");
      card.className = "sector-card" + (isOpen ? "" : " locked");

      if (isOpen) {
        card.href = `/game/${level}/${i}`;
      }

      card.innerHTML = `
        <div class="sector-num">Sector ${i}</div>
        <div class="sector-text">${sectorData.objectiveText}</div>
        <div class="sector-state">${isOpen ? "Open" : "Locked"}</div>
      `;

      grid.appendChild(card);
    }

    modal.classList.remove("hidden");
  }

  function closeSectorModal() {
    document.getElementById("sectorModal").classList.add("hidden");
  }

</script>
<script>
  const currentLevel = <%= Number(user.currentLevel || 1) %>;
  const currentSector = <%= Number(user.currentSector || 1) %>;
  const isAdmin = <%= user.isAdmin ? "true" : "false" %>;
  const completedSectors = <%- JSON.stringify(user.completedSectors || []) %>;
  const gameLevelsData = <%- JSON.stringify(gameLevels) %>;

  function getSectorIcon(objectiveText = "") {
    const text = objectiveText.toLowerCase();

    if (text.includes("collect")) return "🛢";
    if (text.includes("reach")) return "📍";
    if (text.includes("boss")) return "👑";
    return "⚔";
  }

  function openSectorModal(level) {
    const modal = document.getElementById("sectorModal");
    const grid = document.getElementById("sectorGrid");
    const title = document.getElementById("sectorModalTitle");
    const subtitle = document.getElementById("sectorModalSubtitle");
    const progressText = document.getElementById("sectorProgressText");

    const levelData = gameLevelsData[level];
    if (!levelData) return;

    const completedCount = completedSectors.filter(x => x.startsWith(level + "-")).length;

    title.textContent = `Battle ${level}`;
    progressText.textContent = `Completed: ${completedCount} / 10`;
    grid.innerHTML = "";

    for (let i = 1; i <= 10; i++) {
      const sectorData = levelData.sectors[i];
      const sectorKey = `${level}-${i}`;
      const isCompleted = completedSectors.includes(sectorKey);

      const isOpen =
        isAdmin ||
        level < currentLevel ||
        (level === currentLevel && i <= currentSector) ||
        (level === 1 && i === 1);

      const isCurrent =
        level === currentLevel && i === currentSector;

      const el = document.createElement(isOpen ? "a" : "div");
      el.className =
        "sector-card" +
        (isCurrent ? " current" : "") +
        (isCompleted ? " completed" : "") +
        (isOpen ? "" : " locked");

      if (isOpen) {
        el.href = `/game/${level}/${i}`;
      }

      let stateText = "Open";
      let cornerBadge = "";

      if (!isOpen) {
        stateText = "Finish previous";
        cornerBadge = "🔒";
      } else if (isCurrent) {
        stateText = "Current";
        cornerBadge = "➜";
      } else if (isCompleted) {
        stateText = "Completed";
        cornerBadge = "✓";
      }

      el.innerHTML = `
        <div class="sector-corner-badge">${cornerBadge}</div>
        <div class="sector-icon">${getSectorIcon(sectorData.objectiveText)}</div>
        <div class="sector-num">Sector ${i}</div>
        <div class="sector-text">${sectorData.objectiveText}</div>
        <div class="sector-state">${stateText}</div>
      `;

      grid.appendChild(el);
    }

    modal.classList.remove("hidden");
  }

  function closeSectorModal() {
    document.getElementById("sectorModal").classList.add("hidden");
  }

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeSectorModal();
    }
  });

  document.getElementById("sectorModal")?.addEventListener("click", (e) => {
    if (e.target.id === "sectorModal") {
      closeSectorModal();
    }
  });

</script>
</body>
</html>
