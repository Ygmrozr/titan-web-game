          </div>
          <div class="sector-badge" id="sectorModalBadge">10 Sectors</div>
        </div>

        <div class="sector-divider"></div>

        <div class="sector-progress-line">
          <span id="sectorProgressText">Completed: 0 / 10</span>
        </div>
      </div>

      <div class="sector-grid-wrap">
        <div id="sectorGrid" class="sector-grid"></div>
      </div>
    </div>
