<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <title>Market</title>
  <%- include("partials/music") %>
  <style>
    body{
      margin:0;
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background:#111;
      color:white;
      font-family:Arial, Helvetica, sans-serif;
      background-image:url("/images/image2.jpg");
      background-size:cover;
      background-position:center;
    }

    .box{
      width:700px;
      background:rgba(0,0,0,0.74);
      padding:40px;
      border-radius:12px;
    }

    h1{
      text-align:center;
      margin-bottom:12px;
    }

    .coins{
      text-align:center;
      margin-bottom:25px;
      font-size:18px;
    }

    .item{
      display:flex;
      justify-content:space-between;
      align-items:center;
      background:rgba(255,255,255,0.08);
      border-radius:10px;
      padding:14px 16px;
      margin-bottom:12px;
    }

    .actions form{
      display:inline-block;
      margin-left:8px;
    }

    button{
      padding:8px 12px;
      border:none;
      border-radius:6px;
      cursor:pointer;
      font-weight:bold;
    }

    .buy{
      background:#2ecc71;
      color:white;
    }

    .select{
      background:#3498db;
      color:white;
    }

    .owned{
      opacity:0.8;
      font-size:14px;
    }

    a{
      display:inline-block;
      margin-top:20px;
      color:white;
      text-decoration:none;
      font-weight:bold;
    }
  </style>
</head>
<body>
  <div class="box">
    <h1>Market</h1>
    <div class="coins">Coins: <%= user.coins %></div>

    <% marketItems.forEach(item => { %>
      <div class="item">
        <div>
          <div><strong><%= item.name %></strong></div>
          <div>Price: <%= item.price %></div>
          <% if(user.ownedSkins.includes(item.key)){ %>
            <div class="owned">Owned</div>
          <% } %>
          <% if(user.selectedSkin === item.key){ %>
            <div class="owned">Selected</div>
          <% } %>
        </div>

        <div class="actions">
          <% if(!user.ownedSkins.includes(item.key)){ %>
            <form action="/market/buy/<%= item.key %>" method="POST">
              <button class="buy" type="submit">Buy</button>
            </form>
          <% } else if(user.selectedSkin !== item.key) { %>
            <form action="/market/select/<%= item.key %>" method="POST">
              <button class="select" type="submit">Select</button>
            </form>
          <% } %>
        </div>
      </div>
    <% }) %>

    <a href="/menu">← Back to Menu</a>
  </div>
</body>
</html>